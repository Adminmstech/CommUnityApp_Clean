@{
    ViewData["Title"] = "Add Service";
    Layout = "AdminLayout";
}

<div class="container-fluid">
    <div class="card shadow border-0 rounded-4">
        <div class="card-header bg-primary text-white py-3 rounded-top-4">
            <h4 class="mb-0">
                <i class="fa fa-concierge-bell me-2"></i>
                Add New Service
            </h4>
        </div>

        <div class="card-body">

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Business</label>
                    <select id="businessId" class="form-select">
                        <option value="">Select Business</option>
                    </select>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Service Name</label>
                    <input type="text" id="serviceName" class="form-control" />
                </div>

                <div class="col-md-12 mb-3">
                    <label class="form-label fw-bold">Description</label>
                    <textarea id="description"
                              rows="4"
                              class="form-control"></textarea>
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">Price</label>
                    <input type="number" id="price" class="form-control" />
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">Duration (Minutes)</label>
                    <input type="number" id="durationMinutes" class="form-control" />
                </div>

                <div class="col-md-2 mb-3">
                    <label class="form-label fw-bold">Booking Required</label>
                    <select id="isBookingRequired" class="form-select">
                        <option value="true">Yes</option>
                        <option value="false">No</option>
                    </select>
                </div>

                <div class="col-md-2 mb-3">
                    <label class="form-label fw-bold">Active</label>
                    <select id="isActive" class="form-select">
                        <option value="true">Yes</option>
                        <option value="false">No</option>
                    </select>
                </div>

                <div class="col-md-12 mb-4">
                    <label class="form-label fw-bold">Service Images</label>
                    <input type="file"
                           id="serviceImages"
                           class="form-control"
                           multiple
                           accept="image/*" />
                </div>

                <div class="col-md-12 mb-4">
                    <div id="imagePreviewContainer" class="row"></div>
                </div>

                <div class="col-md-12">
                    <button class="btn btn-primary btn-lg rounded-3"
                            onclick="saveService()">
                        <i class="fa fa-save me-2"></i>
                        Save Service
                    </button>
                </div>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        let selectedImages = [];

        $(document).ready(function () {
            loadBusinesses();

            $("#serviceImages").change(function (e) {
                handleImageSelection(e.target.files);
            });
        });

        function loadBusinesses() {
            $.ajax({
                url: "/api/Business/Get_Businesses",
                type: "GET",

                success: function (response) {
                    response.forEach(business => {
                        $("#businessId").append(`
                            <option value="${business.businessId}">
                                ${business.businessName}
                            </option>
                        `);
                    });
                },

                error: function () {
                    Swal.fire("Failed to load businesses.");
                }
            });
        }

        function handleImageSelection(files) {
            selectedImages = [];
            $("#imagePreviewContainer").empty();

            Array.from(files).forEach((file, index) => {
                const reader = new FileReader();

                reader.onload = function (e) {
                    selectedImages.push({
                        imageBase64: e.target.result,
                        isPrimary: index === 0
                    });

                    $("#imagePreviewContainer").append(`
                        <div class="col-md-3 mb-3">
                            <div class="card shadow-sm">
                                <img src="${e.target.result}"
                                     class="card-img-top"
                                     style="height:200px;object-fit:cover;" />

                                <div class="card-body text-center">
                                    <div class="form-check">
                                        <input class="form-check-input primary-image"
                                               type="radio"
                                               name="primaryImage"
                                               value="${index}"
                                               ${index === 0 ? 'checked' : ''} />

                                        <label class="form-check-label">
                                            Primary
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `);
                };

                reader.readAsDataURL(file);
            });

            $(document).on("change", ".primary-image", function () {
                const selectedIndex = parseInt($(this).val());

                selectedImages.forEach((img, i) => {
                    img.isPrimary = i === selectedIndex;
                });
            });
        }

        function saveService() {

            if (!$("#businessId").val()) {
                Swal.fire("Please select business.");
                return;
            }

            if (!$("#serviceName").val()) {
                Swal.fire("Service name is required.");
                return;
            }

            const payload = {
                service: {
                    businessId: parseInt($("#businessId").val()),
                    serviceName: $("#serviceName").val(),
                    description: $("#description").val(),
                    price: parseFloat($("#price").val()) || 0,
                    durationMinutes: parseInt($("#durationMinutes").val()) || 0,
                    isBookingRequired: $("#isBookingRequired").val() === "true",
                    isActive: $("#isActive").val() === "true"
                },
                images: selectedImages
            };

            $.ajax({
                url: "/api/Service/UploadService",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(payload),

                success: function (res) {
                    Swal.fire({
                        icon: "success",
                        title: "Success",
                        text: "Service added successfully."
                    });

                    resetForm();
                },

                error: function (xhr) {
                    Swal.fire({
                        icon: "error",
                        title: "Error",
                        text: xhr.responseJSON?.resultMessage || "Failed to save service."
                    });
                }
            });
        }

        function resetForm() {
            $("#businessId").val('');
            $("#serviceName").val('');
            $("#description").val('');
            $("#price").val('');
            $("#durationMinutes").val('');
            $("#isBookingRequired").val('true');
            $("#isActive").val('true');
            $("#serviceImages").val('');
            $("#imagePreviewContainer").empty();
            selectedImages = [];
        }
    </script>
}