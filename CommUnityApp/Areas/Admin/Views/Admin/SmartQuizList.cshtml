@{
    ViewData["Title"] = "Smart Quiz List";
    Layout = "AdminLayout";
}


<style>

    .quiz-img {
        width: 70px;
        height: 70px;
        border-radius: 6px;
        object-fit: cover;
        border: 1px solid #ddd;
    }

    .table td {
        vertical-align: middle;
    }

    .badge-active {
        background: #198754;
        color: #fff;
        padding: 6px 12px;
        border-radius: 20px;
    }

    .badge-inactive {
        background: #dc3545;
        color: #fff;
        padding: 6px 12px;
        border-radius: 20px;
    }

    .card-header h4 {
        margin: 0;
    }

    .action-btn {
        margin-right: 5px;
    }

</style>

<div class="container-fluid mt-4">

    <div class="card shadow">

        <div class="card-header bg-primary text-white">

            <div class="row">

                <div class="col-md-6">

                    <h4>
                        <i class="fa fa-list"></i>
                        Smart Quiz List
                    </h4>

                </div>

                <div class="col-md-6 text-end">

                    <a href="/Admin/Admin/AddSmartQuiz"
                       class="btn btn-light">

                        <i class="fa fa-plus"></i>

                        Add Smart Quiz

                    </a>

                </div>

            </div>

        </div>

        <div class="card-body">

            <div class="row mb-3">

                <div class="col-md-4">

                    <input
                        type="text"
                        id="txtSearch"
                        class="form-control"
                        placeholder="Search Quiz Name / Quiz Code..." />

                </div>

                <div class="col-md-2">

                    <button
                        class="btn btn-primary w-100"
                        onclick="searchQuiz()">

                        <i class="fa fa-search"></i>

                        Search

                    </button>

                </div>

                <div class="col-md-2">

                    <button
                        class="btn btn-secondary w-100"
                        onclick="loadQuizzes()">

                        <i class="fa fa-refresh"></i>

                        Refresh

                    </button>

                </div>

            </div>

            <div class="table-responsive">

                <table
                    class="table table-bordered table-hover">

                    <thead class="table-dark">

                        <tr>

                            <th width="60">
                                #
                            </th>

                            <th width="90">
                                Banner
                            </th>

                            <th>
                                Quiz Name
                            </th>

                            <th>
                                Quiz Code
                            </th>

                            <th width="120">
                                Reward Coins
                            </th>

                            <th width="180">
                                Start Date
                            </th>

                            <th width="180">
                                End Date
                            </th>

                            <th width="120">
                                Questions
                            </th>

                            <th width="120">
                                Status
                            </th>

                            <th width="180">
                                Action
                            </th>

                        </tr>

                    </thead>

                    <tbody id="quizTableBody">
                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<div
    class="modal fade"
    id="deleteModal"
    tabindex="-1">

    <div class="modal-dialog">

        <div class="modal-content">

            <div class="modal-header bg-danger text-white">

                <h5>

                    Delete Smart Quiz

                </h5>

            </div>

            <div class="modal-body">

                Are you sure you want to delete this Smart Quiz?

            </div>

            <div class="modal-footer">

                <button
                    class="btn btn-secondary"
                    data-bs-dismiss="modal">

                    Cancel

                </button>

                <button
                    class="btn btn-danger"
                    id="btnDeleteQuiz">

                    Delete

                </button>

            </div>

        </div>

    </div>

</div>

@section Scripts{

<script>

    let allQuizzes = [];

    let deleteQuizId = 0;

    $(document).ready(function () {

        loadQuizzes();

        $("#txtSearch").keyup(function (e) {

            if (e.keyCode == 13) {

                searchQuiz();

            }

        });

    });
    function loadQuizzes() {

        $.ajax({

            url: "/api/SmartQuiz/GetAllSmartQuiz",

            type: "GET",

            success: function (res) {

                console.log(res);

                if (res.status || res.Status) {

                    allQuizzes = res.data || res.Data;

                    bindGrid(allQuizzes);

                }
                else {

                    alert(res.resultMessage || "No records found.");

                }

            },

            error: function (xhr) {

                console.log(xhr);

                alert("Unable to load Smart Quiz List.");

            }

        });

    }


    function bindGrid(data) {

        let html = "";

        if (!data || data.length === 0) {

            html = `
                    <tr>

                        <td colspan="10"
                            class="text-center text-danger">

                            No Smart Quiz Available

                        </td>

                    </tr>`;

        }
        else {

            $.each(data, function (i, item) {

                let image = "";

                if (item.smartQuizImage &&
                    item.smartQuizImage !== "") {

                    image = `
                            <img
                                src="/SmartQuiz/${item.quizId}/${item.smartQuizImage}"
                                class="quiz-img" />`;

                }
                else {

                    image = `
                            <img
                                src="/images/no-image.png"
                                class="quiz-img" />`;

                }

                let status = "";

                if (item.status) {

                    status = `
                            <span class="badge-active">

                                Active

                            </span>`;

                }
                else {

                    status = `
                            <span class="badge-inactive">

                                Inactive

                            </span>`;

                }

                html += `

                    <tr>

                        <td>

                            ${i + 1}

                        </td>

                        <td>

                            ${image}

                        </td>

                        <td>

                            ${item.smartQuizName}

                        </td>

                        <td>

                            ${item.smartQuizCode}

                        </td>

                        <td>

                            ${item.rewardCoins}

                        </td>

                        <td>

                            ${formatDate(item.startDate)}

                        </td>

                        <td>

                            ${formatDate(item.endDate)}

                        </td>

                        <td>

                            ${item.totalQuestions}

                        </td>

                        <td>

                            ${status}

                        </td>

                        <td>

                            <button
                                class="btn btn-warning btn-sm action-btn"
                                onclick="editQuiz(${item.quizId})">

                                <i class="fa fa-edit"></i>

                                Edit

                            </button>

                            <button
                                class="btn btn-danger btn-sm"
                                onclick="showDelete(${item.quizId})">

                                <i class="fa fa-trash"></i>

                                Delete

                            </button>

                        </td>

                    </tr>`;

            });

        }

        $("#quizTableBody").html(html);

    }


    function searchQuiz() {

        let search = $("#txtSearch")
            .val()
            .toLowerCase();

        if (search === "") {

            bindGrid(allQuizzes);

            return;

        }

        let filtered = allQuizzes.filter(function (x) {

            return (x.smartQuizName || "")
                .toLowerCase()
                .includes(search)

                ||

                (x.smartQuizCode || "")
                    .toLowerCase()
                    .includes(search);

        });

        bindGrid(filtered);

    }

        function editQuiz(quizId) {

            window.location.href =
                "/Admin/Admin/AddSmartQuiz?quizId=" + quizId;

        }


        function showDelete(id) {

            deleteQuizId = id;

            var modal = new bootstrap.Modal(
                document.getElementById("deleteModal")
            );

            modal.show();

        }


        $("#btnDeleteQuiz").click(function () {

            deleteQuiz(deleteQuizId);

        });


        function deleteQuiz(id) {

            $.ajax({

                url: "/api/SmartQuiz/DeleteSmartQuiz?quizId=" + id,

                type: "POST",

                success: function (res) {

                    bootstrap.Modal
                        .getInstance(document.getElementById("deleteModal"))
                        .hide();

                    if (res.status || res.Status) {

                        alert(res.resultMessage || "Deleted Successfully.");

                        loadQuizzes();

                    }
                    else {

                        alert(res.resultMessage);

                    }

                },

                error: function (xhr) {

                    console.log(xhr);

                    alert("Unable to delete Smart Quiz.");

                }

            });

        }


        function formatDate(value) {

            if (value == null || value == "")
                return "";

            let date = new Date(value);

            let day = String(date.getDate()).padStart(2, '0');
            let month = String(date.getMonth() + 1).padStart(2, '0');
            let year = date.getFullYear();

            let hour = date.getHours();
            let minute = String(date.getMinutes()).padStart(2, '0');

            let ampm = hour >= 12 ? "PM" : "AM";

            hour = hour % 12;

            if (hour == 0)
                hour = 12;

            return day + "/"
                + month + "/"
                + year + " "
                + hour + ":"
                + minute + " "
                + ampm;

        }


    </script>

}