@{
    ViewData["Title"] = "Live Auctions";
    Layout = "AdminLayout";
}

<div class="container-fluid">
    <div class="card shadow border-0 rounded-4">
        <div class="card-header bg-primary text-white py-3 rounded-top-4 d-flex justify-content-between align-items-center">
            <h4 class="mb-0">
                <i class="fa fa-gavel me-2"></i> Live Auctions Management
            </h4>
        </div>

        <div class="card-body">

            <div class="row mb-4">
                <div class="col-md-6">
                    <input type="text"
                           id="searchBox"
                           class="form-control"
                           placeholder="Search by item, user..." />
                </div>

                <div class="col-md-3">
                    <select id="statusFilter" class="form-select">
                        <option value="">All Auctions</option>
                        <option value="Live">Live</option>
                        <option value="Upcoming">Upcoming</option>
                        <option value="Closed">Closed</option>
                    </select>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Item</th>
                            <th>User</th>
                            <th>Condition</th>
                            <th>Reserve Price</th>
                            <th>Min Deposit</th>
                            <th>Start Time</th>
                            <th>End Time</th>
                            <th>Location</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody id="auctionTableBody">
                        <tr>
                            <td colspan="10" class="text-center py-4">
                                Loading auctions...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

<!-- Details Modal -->
<div class="modal fade" id="auctionDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="fa fa-gavel me-2"></i>
                    Auction Details
                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body" id="auctionDetailsBody">
                Loading...
            </div>

        </div>
    </div>
</div>

@section Scripts {

    <script>

        let allAuctions = [];

        $(document).ready(function () {

            loadAuctions();

            $("#searchBox").on("keyup", filterAuctions);
            $("#statusFilter").on("change", filterAuctions);

        });

        function loadAuctions() {

            $.ajax({
                url: "/api/Auction/Get_AdminLiveAuctions",
                type: "GET",

                success: function (response) {

                    allAuctions = response;
                    renderAuctions(response);

                },

                error: function () {

                    Swal.fire({
                        icon: "error",
                        title: "Error",
                        text: "Failed to load auctions."
                    });

                }
            });

        }

        function filterAuctions() {

            const search = $("#searchBox").val().toLowerCase();
            const status = $("#statusFilter").val();

            const filtered = allAuctions.filter(item => {

                const matchesSearch =
                    (item.itemTitle || '').toLowerCase().includes(search) ||
                    (item.userName || '').toLowerCase().includes(search);

                const matchesStatus =
                    !status || item.auctionDisplayStatus === status;

                return matchesSearch && matchesStatus;

            });

            renderAuctions(filtered);

        }

        function renderAuctions(auctions) {

            const tbody = $("#auctionTableBody");
            tbody.empty();

            if (!auctions || auctions.length === 0) {

                tbody.html(`
                    <tr>
                        <td colspan="10" class="text-center py-4">
                            No auctions found.
                        </td>
                    </tr>
                `);

                return;
            }

            auctions.forEach(item => {

                let statusBadge = '';

                if (item.auctionDisplayStatus === "Live") {
                    statusBadge = '<span class="badge bg-success">Live</span>';
                }
                else if (item.auctionDisplayStatus === "Upcoming") {
                    statusBadge = '<span class="badge bg-warning text-dark">Upcoming</span>';
                }
                else {
                    statusBadge = '<span class="badge bg-secondary">Closed</span>';
                }

                tbody.append(`
                    <tr>

                        <td>
                            <strong>${item.itemTitle || ''}</strong>
                        </td>

                        <td>${item.userName || ''}</td>

                        <td>${item.itemCondition || '-'}</td>

                        <td>₹${item.reservePrice || 0}</td>

                        <td>₹${item.minDeposite || 0}</td>

                        <td>${formatDateTime(item.startTime)}</td>

                        <td>${formatDateTime(item.endTime)}</td>

                        <td>${item.itemLocation || '-'}</td>

                        <td>${statusBadge}</td>

                        <td>
                            <button class="btn btn-primary btn-sm"
                                    onclick="viewDetails(${item.auctionId})">
                                <i class="fa fa-eye"></i> Details
                            </button>
                        </td>

                    </tr>
                `);

            });

        }

        function viewDetails(auctionId) {

            $("#auctionDetailsBody").html(`
                <div class="text-center p-5">
                    <div class="spinner-border text-primary"></div>
                </div>
            `);

            new bootstrap.Modal(document.getElementById("auctionDetailsModal")).show();

            $.ajax({

                url: `/api/Auction/Get_AuctionByAuctionId?AuctionId=${auctionId}`,
                type: "GET",

                success: function (response) {

                    if (!response || response.length === 0) {

                        $("#auctionDetailsBody").html(`
                            <div class="alert alert-warning">
                                Auction details not found.
                            </div>
                        `);

                        return;
                    }

                    const auction = response[0];

                    let imageHtml = '';

                    if (auction.images && auction.images.length > 0) {

                        auction.images.forEach(img => {

                            imageHtml += `
                                <div class="col-md-4 mb-3">
                                    <img src="/${img.imageUrl}"
                                         class="img-fluid rounded border shadow-sm"
                                         style="height:220px;width:100%;object-fit:cover;" />
                                </div>
                            `;
                        });
                    }
                    else {

                        imageHtml = `
                            <div class="col-12">
                                <img src="/images/no-image.png"
                                     class="img-fluid rounded border" />
                            </div>
                        `;
                    }

                    $("#auctionDetailsBody").html(`

                        <div class="row mb-4">
                            ${imageHtml}
                        </div>

                        <div class="table-responsive">

                            <table class="table table-bordered">

                                <tr>
                                    <th width="220">Item Title</th>
                                    <td>${auction.itemTitle || ''}</td>
                                </tr>

                                <tr>
                                    <th>Description</th>
                                    <td>${auction.itemDescription || ''}</td>
                                </tr>

                                <tr>
                                    <th>User</th>
                                    <td>${auction.user || ''}</td>
                                </tr>

                                <tr>
                                    <th>Condition</th>
                                    <td>${auction.itemCondition || ''}</td>
                                </tr>

                                <tr>
                                    <th>Reserve Price</th>
                                    <td>₹${auction.reservePrice || 0}</td>
                                </tr>

                                <tr>
                                    <th>Price Increment</th>
                                    <td>₹${auction.priceIncrement || 0}</td>
                                </tr>

                                <tr>
                                    <th>Minimum Deposit</th>
                                    <td>₹${auction.minDeposite || 0}</td>
                                </tr>

                                <tr>
                                    <th>Location</th>
                                    <td>${auction.itemLocation || ''}</td>
                                </tr>

                                <tr>
                                    <th>Start Time</th>
                                    <td>${formatDateTime(auction.startTime)}</td>
                                </tr>

                                <tr>
                                    <th>End Time</th>
                                    <td>${formatDateTime(auction.endTime)}</td>
                                </tr>

                                <tr>
                                    <th>Created By</th>
                                    <td>${auction.createdBy || ''}</td>
                                </tr>

                                <tr>
                                    <th>Created Date</th>
                                    <td>${formatDateTime(auction.createdAt)}</td>
                                </tr>

                            </table>

                        </div>
                    `);

                },

                error: function () {

                    $("#auctionDetailsBody").html(`
                        <div class="alert alert-danger">
                            Failed to load auction details.
                        </div>
                    `);

                }

            });

        }

        function formatDateTime(dateString) {

            if (!dateString)
                return "-";

            return new Date(dateString).toLocaleString();

        }

    </script>

}