@{
    ViewData["Title"] = "Live Auctions";
    Layout = "AdminLayout";
}

<div class="container-fluid">
    <div class="card shadow border-0 rounded-4">
        <div class="card-header bg-primary text-white py-3 rounded-top-4 d-flex justify-content-between align-items-center">
            <h4 class="mb-0">
                <i class="fa fa-gavel me-2"></i> Live Auctions Management
            </h4>
        </div>

        <div class="card-body">

            <div class="row mb-4">
                <div class="col-md-6">
                    <input type="text"
                           id="searchBox"
                           class="form-control"
                           placeholder="Search by item, user..." />
                </div>

                <div class="col-md-3">
                    <select id="statusFilter" class="form-select">
                        <option value="">All Auctions</option>
                        <option value="Live">Live</option>
                        <option value="Upcoming">Upcoming</option>
                        <option value="Closed">Closed</option>
                    </select>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Item</th>
                            <th>User</th>
                            <th>Condition</th>
                            <th>Reserve Price</th>
                            <th>Min Deposit</th>
                            <th>Start Time</th>
                            <th>End Time</th>
                            <th>Location</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody id="auctionTableBody">
                        <tr>
                            <td colspan="10" class="text-center py-4">
                                Loading auctions...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>
<div class="row mb-4">

    <div class="col-md-3">
        <div class="card bg-info text-white">
            <div class="card-body text-center">
                <h3>${response.totalRegisteredUsers}</h3>
                <small>Participants</small>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-success text-white">
            <div class="card-body text-center">
                <h3 id="totalBids">${response.totalBids}</h3>
                <small>Total Bids</small>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-warning">
            <div class="card-body text-center">
                <h3 id="highestBid">
                    ₹${response.highestBid}
                </h3>
                <small>Highest Bid</small>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card bg-primary text-white">
            <div class="card-body text-center">
                <h6 id="highestBidder">
                    ${response.highestBidder}
                </h6>
                <small>Highest Bidder</small>
            </div>
        </div>
    </div>

</div>

<!-- Details Modal -->
<div class="modal fade" id="auctionDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="fa fa-gavel me-2"></i>
                    Auction Details
                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body" id="auctionDetailsBody">
                Loading...
            </div>

        </div>
    </div>
    
</div>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
@section Scripts {

    <script>

        let allAuctions = [];

        $(document).ready(function () {

            loadAuctions();

            $("#searchBox").on("keyup", filterAuctions);
            $("#statusFilter").on("change", filterAuctions);

        });

        function loadAuctions() {

            $.ajax({
                url: "/api/Auction/Get_AdminLiveAuctions",
                type: "GET",

                success: function (response) {

                    allAuctions = response;
                    renderAuctions(response);

                },

                error: function () {

                    Swal.fire({
                        icon: "error",
                        title: "Error",
                        text: "Failed to load auctions."
                    });

                }
            });

        }

        function filterAuctions() {

            const search = $("#searchBox").val().toLowerCase();
            const status = $("#statusFilter").val();

            const filtered = allAuctions.filter(item => {

                const matchesSearch =
                    (item.itemTitle || '').toLowerCase().includes(search) ||
                    (item.userName || '').toLowerCase().includes(search);

                const matchesStatus =
                    !status || item.auctionDisplayStatus === status;

                return matchesSearch && matchesStatus;

            });

            renderAuctions(filtered);

        }

        function renderAuctions(auctions) {

            const tbody = $("#auctionTableBody");
            tbody.empty();

            if (!auctions || auctions.length === 0) {

                tbody.html(`
                    <tr>
                        <td colspan="10" class="text-center py-4">
                            No auctions found.
                        </td>
                    </tr>
                `);

                return;
            }

            auctions.forEach(item => {

                let statusBadge = '';

                if (item.auctionDisplayStatus === "Live") {
                    statusBadge = '<span class="badge bg-success">Live</span>';
                }
                else if (item.auctionDisplayStatus === "Upcoming") {
                    statusBadge = '<span class="badge bg-warning text-dark">Upcoming</span>';
                }
                else {
                    statusBadge = '<span class="badge bg-secondary">Closed</span>';
                }

                tbody.append(`
                    <tr>

                        <td>
                            <strong>${item.itemTitle || ''}</strong>
                        </td>

                        <td>${item.userName || ''}</td>

                        <td>${item.itemCondition || '-'}</td>

                        <td>₹${item.reservePrice || 0}</td>

                        <td>₹${item.minDeposite || 0}</td>

                        <td>${formatDateTime(item.startTime)}</td>

                        <td>${formatDateTime(item.endTime)}</td>

                        <td>${item.itemLocation || '-'}</td>

                        <td>${statusBadge}</td>

                        <td>
                            <button class="btn btn-primary btn-sm"
                                    onclick="viewDetails(${item.auctionId})">
                                <i class="fa fa-eye"></i> Details
                            </button>
                        </td>

                    </tr>
                `);

            });

        }

        function viewDetails(auctionId) {

            $("#auctionDetailsBody").html(`
                <div class="text-center p-5">
                    <div class="spinner-border text-primary"></div>
                </div>
            `);

            new bootstrap.Modal(document.getElementById("auctionDetailsModal")).show();

            $.ajax({

                url: `/api/Auction/Get_AdminAuctionDetails?auctionId=${auctionId}`,
                type: "GET",

                        success: function (response) {

            if (!response || response.resultId !== 1) {

                $("#auctionDetailsBody").html(`
                    <div class="alert alert-warning">
                        Auction details not found.
                    </div>
                `);

                return;
            }

            const auction = response.auction;
            const registeredUsers = response.registeredUsers || [];
            const bidHistory = response.bidHistory || [];

            let imageHtml = "";

            if (auction.images && auction.images.length > 0) {

                auction.images.forEach(img => {

                    imageHtml += `
                        <div class="col-md-4 mb-3">
                            <img src="/${img.imageUrl}"
                                 class="img-fluid rounded border shadow-sm"
                                 style="height:220px;width:100%;object-fit:cover;">
                        </div>
                    `;
                });
            }

            let participantsHtml = "";

            if (registeredUsers.length > 0) {

                registeredUsers.forEach(user => {

                    participantsHtml += `
                        <tr>
                            <td>${user.userName}</td>
                            <td>${user.email || ''}</td>
                            <td>
                                <span class="badge bg-success">
                                    ${user.paymentStatus}
                                </span>
                            </td>
                        </tr>
                    `;
                });
            }

            let bidHistoryHtml = "";

            if (bidHistory.length > 0) {

                bidHistory.forEach(bid => {

                    bidHistoryHtml += `
                        <tr>
                            <td>${bid.userName}</td>
                            <td>₹${bid.bidAmount}</td>
                            <td>${formatDateTime(bid.bidTime)}</td>
                        </tr>
                    `;
                });
            }

            $("#auctionDetailsBody").html(`

                <div class="row mb-4">
                    ${imageHtml}
                </div>

                <div class="row mb-4">

                    <div class="col-md-3">
                        <div class="card bg-info text-white">
                            <div class="card-body text-center">
                                <h3>${response.totalRegisteredUsers}</h3>
                                <small>Participants</small>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="card bg-success text-white">
                            <div class="card-body text-center">
                                <h3 id="totalBids">
                                    ${response.totalBids}
                                </h3>
                                <small>Total Bids</small>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="card bg-warning">
                            <div class="card-body text-center">
                                <h3 id="highestBid">
                                    ₹${response.highestBid}
                                </h3>
                                <small>Highest Bid</small>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="card bg-primary text-white">
                            <div class="card-body text-center">
                                <h6 id="highestBidder">
                                    ${response.highestBidder}
                                </h6>
                                <small>Highest Bidder</small>
                            </div>
                        </div>
                    </div>

                </div>

                <table class="table table-bordered">

                    <tr>
                        <th>Item Title</th>
                        <td>${auction.itemTitle || ''}</td>
                    </tr>

                    <tr>
                        <th>Description</th>
                        <td>${auction.itemDescription || ''}</td>
                    </tr>

                    <tr>
                        <th>User</th>
                        <td>${auction.user || ''}</td>
                    </tr>

                    <tr>
                        <th>Reserve Price</th>
                        <td>₹${auction.reservePrice || 0}</td>
                    </tr>

                </table>

                <h5 class="mt-4">Bid Participants</h5>

                <table class="table table-bordered">

                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Status</th>
                        </tr>
                    </thead>

                    <tbody>
                        ${participantsHtml}
                    </tbody>

                </table>

                <h5 class="mt-4">Latest Bids</h5>

                <table class="table table-bordered">

                    <thead class="table-dark">
                        <tr>
                            <th>Bidder</th>
                            <th>Bid Amount</th>
                            <th>Bid Time</th>
                        </tr>
                    </thead>

                    <tbody id="bidHistoryBody">
                        ${bidHistoryHtml}
                    </tbody>

                </table>

            `);
        },

                error: function () {

                    $("#auctionDetailsBody").html(`
                        <div class="alert alert-danger">
                            Failed to load auction details.
                        </div>
                    `);

                }

            });

        }
                const connection = new signalR.HubConnectionBuilder()
            .withUrl("/auctionHub")
            .withAutomaticReconnect()
            .build();

        connection.start()
            .then(function () {
                console.log("Connected to SignalR");
            })
            .catch(function (err) {
                console.error("SignalR Connection Error:", err);
            });

        connection.onclose(function (err) {
            console.log("SignalR Disconnected", err);
        });

        connection.onreconnecting(function () {
            console.log("SignalR Reconnecting...");
        });

        connection.onreconnected(function () {
            console.log("SignalR Reconnected");
        });

                connection.on("RecentBidsUpdated", function (bids) {

            let html = "";

            bids.forEach(function (bid) {

                html += `
                    <tr>
                        <td>${bid.userName}</td>
                        <td>₹${bid.bidAmount}</td>
                        <td>${formatDateTime(bid.bidTime)}</td>
                    </tr>
                `;
            });

            $("#bidHistoryBody").html(html);

            $("#totalBids").text(bids.length);

            const highestBid =
                bids.sort((a, b) => b.bidAmount - a.bidAmount)[0];

            $("#highestBid")
                .text(`₹${highestBid.bidAmount}`);

            $("#highestBidder")
                .text(highestBid.userName);
        });
        function formatDateTime(dateString) {

            if (!dateString)
                return "-";

            return new Date(dateString).toLocaleString();

        }

    </script>

}