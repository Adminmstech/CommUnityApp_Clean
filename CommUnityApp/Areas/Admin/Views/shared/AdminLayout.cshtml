@{
    var adminName = Context.Session.GetString("AdminName") ?? "Super Admin";
    var adminInitial = adminName.Substring(0, 1).ToUpper();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Super Admin Portal</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />

    <style>
        :root {
            --sidebar-bg: #0f172a;
            --sidebar-hover: #1e293b;
            --primary: #2563eb;
            --accent: #f59e0b;
            --text-muted: #94a3b8;
            --bg-light: #f8fafc;
            --border: #e2e8f0;
        }

        html, body {
            height: 100%;
            margin: 0;
            overflow: hidden;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background: var(--bg-light);
        }

        .layout {
            display: flex;
            height: 100vh;
        }

        .sidebar {
            width: 280px;
            background: var(--sidebar-bg);
            color: white;
            padding: 24px 18px;
            flex-shrink: 0;
            transition: all .3s ease;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
        }

            .sidebar.collapsed {
                width: 0;
                padding: 0;
                overflow: hidden;
            }

        .brand {
            font-size: 22px;
            font-weight: 700;
            margin-bottom: 32px;
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 0 12px;
        }

            .brand i {
                color: var(--primary);
                font-size: 24px;
            }

        .nav-section-title {
            color: #64748b;
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1px;
            margin: 18px 12px 8px;
            text-transform: uppercase;
        }

        .nav {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

            .nav a {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 12px 14px;
                border-radius: 12px;
                color: var(--text-muted);
                text-decoration: none;
                font-weight: 600;
                transition: all .2s ease;
            }

                .nav a:hover,
                .nav a.active {
                    background: var(--sidebar-hover);
                    color: white;
                }

            .nav i {
                width: 20px;
                text-align: center;
                font-size: 17px;
            }

        .main {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: var(--bg-light);
        }

        .topbar {
            height: 70px;
            background: white;
            border-bottom: 1px solid var(--border);
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 24px;
            flex-shrink: 0;
        }

        .top-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .menu-btn {
            font-size: 20px;
            background: none;
            border: none;
            cursor: pointer;
            color: #334155;
        }

        .page-title {
            font-weight: 700;
            font-size: 20px;
            color: #0f172a;
        }

        .top-actions {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .notification-btn {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            border: 1px solid var(--border);
            background: white;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
        }

        .content {
            flex: 1;
            overflow-y: auto;
            padding: 30px;
        }

        .footer {
            height: 50px;
            background: white;
            border-top: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            color: #64748b;
        }

        .profile-avatar {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: var(--primary);
            color: white;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        @@media (max-width: 768px) {
            .sidebar {
                position: fixed;
                top: 0;
                left: -280px;
                height: 100vh;
                z-index: 1100;
            }

                .sidebar.open {
                    left: 0;
                }

            .mobile-overlay {
                position: fixed;
                inset: 0;
                background: rgba(15, 23, 42, 0.6);
                z-index: 1000;
                display: none;
            }

                .mobile-overlay.show {
                    display: block;
                }

            .content {
                padding: 20px;
            }
        }
    </style>
</head>
<body>

    <div class="mobile-overlay" id="overlay" onclick="closeSidebar()"></div>

    <div class="layout">

        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="brand">
                <i class="fa-solid fa-shield-halved"></i>
                <span>Super Admin</span>
            </div>

            <nav class="nav">
                <a href="@Url.Action("Index", "Dashboard", new { area = "Admin" })">
                    <i class="fa-solid fa-chart-line"></i> Dashboard
                </a>

                <div class="nav-section-title">Business</div>
                <a href="@Url.Action("AddBusiness", "Admin", new { area = "Admin" })">
                    <i class="fa-solid fa-plus-circle"></i> Add Business
                </a>
                <a href="@Url.Action("Business", "Admin", new { area = "Admin" })">
                    <i class="fa-solid fa-building"></i> Manage Businesses
                </a>

                <div class="nav-section-title">Organisation</div>
                <a href="@Url.Action("AddCommunity", "Admin", new { area = "Admin" })">
                    <i class="fa-solid fa-plus"></i> Add Organisation
                </a>
                <a href="@Url.Action("ManageCommunity", "Admin", new { area = "Admin" })">
                    <i class="fa-solid fa-sitemap"></i> Manage Organisations
                </a>

                <div class="nav-section-title">Users</div>
                <a href="@Url.Action("Users", "Admin", new { area = "Admin" })">
                    <i class="fa-solid fa-users"></i> All Users
                </a>
              @*   <a href="@Url.Action("BlockedUsers", "User", new { area = "Admin" })">
                    <i class="fa-solid fa-user-lock"></i> Blocked Users
                </a> *@

                <div class="nav-section-title">Communication</div>
                <a href="@Url.Action("Notifications", "Communication", new { area = "Admin" })">
                    <i class="fa-solid fa-bell"></i> Send Notification
                </a>
                <a href="@Url.Action("Broadcast", "Communication", new { area = "Admin" })">
                    <i class="fa-solid fa-bullhorn"></i> Broadcast Message
                </a>
                <a href="@Url.Action("EmailUsers", "Communication", new { area = "Admin" })">
                    <i class="fa-solid fa-envelope"></i> Email Users
                </a>

                <div class="nav-section-title">Management</div>
                <a href="@Url.Action("Promotions", "Promotion", new { area = "Admin" })">
                    <i class="fa-solid fa-tags"></i> Promotions
                </a>
                <a href="@Url.Action("LiveAuctions", "Auction", new { area = "Admin" })">
                    <i class="fa-solid fa-gavel"></i> Live Auctions
                </a>
                <a href="@Url.Action("Appointments", "Appointment", new { area = "Admin" })">
                    <i class="fa-solid fa-calendar-check"></i> Appointments
                </a>
                <a href="@Url.Action("Reports", "Reports", new { area = "Admin" })">
                    <i class="fa-solid fa-chart-pie"></i> Reports
                </a>
                <a href="@Url.Action("Settings", "Settings", new { area = "Admin" })">
                    <i class="fa-solid fa-gear"></i> Settings
                </a>
            </nav>

            <div class="mt-auto">
                <a href="@Url.Action("Logout", "Account", new { area = "Admin" })"
                   class="nav-link text-danger fw-bold d-flex align-items-center gap-2 px-3">
                    <i class="fa-solid fa-right-from-bracket"></i> Logout
                </a>
            </div>
        </aside>

        <!-- Main -->
        <div class="main">

            <!-- Topbar -->
            <header class="topbar">
                <div class="top-left">
                    <button class="menu-btn" onclick="toggleSidebar()">
                        <i class="fa-solid fa-bars"></i>
                    </button>
                    <span class="page-title">@ViewData["Title"]</span>
                </div>

                <div class="top-actions">
                    <button class="notification-btn">
                        <i class="fa-solid fa-bell"></i>
                    </button>

                    <div class="dropdown">
                        <button class="btn btn-light d-flex align-items-center gap-2 fw-bold"
                                data-bs-toggle="dropdown">
                            <div class="profile-avatar">@adminInitial</div>
                            @adminName
                        </button>

                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="#">My Profile</a></li>
                            <li><a class="dropdown-item" href="#">Settings</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item text-danger"
                                   href="@Url.Action("Logout", "Account", new { area = "Admin" })">
                                    Logout
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </header>

            <!-- Content -->
            <main class="content">
                @RenderBody()
            </main>

            <!-- Footer -->
            <footer class="footer">
                © 2026 CommUnity Super Admin Portal. All rights reserved.
            </footer>

        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        const sidebar = document.getElementById("sidebar");
        const overlay = document.getElementById("overlay");

        function toggleSidebar() {
            if (window.innerWidth <= 768) {
                sidebar.classList.toggle("open");
                overlay.classList.toggle("show");
            } else {
                sidebar.classList.toggle("collapsed");
            }
        }

        function closeSidebar() {
            sidebar.classList.remove("open");
            overlay.classList.remove("show");
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>