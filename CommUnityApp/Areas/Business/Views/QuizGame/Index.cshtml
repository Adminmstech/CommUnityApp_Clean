@model IEnumerable<CommUnityApp.ApplicationCore.Models.QuizGameDto>
@{
    ViewData["Title"] = "Quiz Games";
    Layout = "_BusinessLayout";
}

<div class="container-xxl px-3 px-md-4">
    <div class="d-flex align-items-center mb-4">
        <div class="me-auto">
            <h2 class="fw-800 mb-1">Quiz Games</h2>
            <p class="text-muted">Manage your interactive quizzes and view performance.</p>
        </div>
        <a href="@Url.Action("Create", "QuizGame")" class="btn btn-primary rounded-pill px-4 fw-600 shadow-sm">
            <i class="fa-solid fa-plus me-2"></i> Create New Quiz
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Quiz Name</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var quiz in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary bg-opacity-10 rounded-3 p-2 me-3">
                                            <i class="fa-solid fa-list-check text-primary"></i>
                                        </div>
                                        <div>
                                            <div class="fw-700">@quiz.GameName</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="text-truncate" style="max-width: 300px;">@quiz.Description</div>
                                </td>
                                <td>
                                    @if (quiz.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success rounded-pill px-3">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary rounded-pill px-3">Inactive</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a href="@Url.Action("Create", "QuizGame", new { quizId = quiz.QuizId })" class="btn btn-sm btn-light rounded-pill px-3 me-2">
                                        <i class="fa-solid fa-pen-to-square me-1"></i> Edit
                                    </a>
                                    <button type="button" class="btn btn-sm btn-outline-danger rounded-pill px-3" onclick="deleteQuiz(@quiz.QuizId)">
                                        <i class="fa-solid fa-trash me-1"></i> Delete
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-face-meh fa-3x mb-3 d-block opacity-25"></i>
                                No quizzes found. Create your first quiz to get started!
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function deleteQuiz(id) {
            if (confirm('Are you sure you want to delete this quiz?')) {
                $.post('@Url.Action("Delete", "QuizGame")/' + id, function(response) {
                    if (response.success) {
                        location.reload();
                    } else {
                        alert('Error: ' + response.message);
                    }
                });
            }
        }
    </script>
}
