@model CommUnityApp.ApplicationCore.Models.AddUpdateSpinGameRequest
@{
    ViewData["Title"] = Model.GameId > 0 ? "Edit Spin Game" : "Create Spin Game";
    Layout = "_BusinessLayout";
}

<div class="container-fluid">
    <div class="d-flex align-items-center mb-4">
        <img src="~/img/spinwheel.png" class="brand-image img-fluid me-4" alt="Spin Wheel" style="width: 80px;" />
        <div class="me-auto">
            <h2 class="fw-800 mb-1">@ViewData["Title"]</h2>
            <p class="text-muted">Configure your spin wheel game across 3 tabs.</p>
        </div>
        <a href="@Url.Action("Index", "SpinGame")" class="btn btn-light rounded-pill px-4 fw-600">
            <i class="fa-solid fa-arrow-left me-2"></i> Back to Spin Games
        </a>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger rounded-4 shadow-sm mb-4">
            <i class="fa-solid fa-circle-exclamation me-2"></i> @ViewBag.Error
        </div>
    }

    <form asp-action="Create" method="post" id="spinGameForm" novalidate>
        <input type="hidden" asp-for="GameId" />
        <input type="hidden" asp-for="BusinessId" />
        <input type="hidden" asp-for="ConfigId" />
        <input type="hidden" asp-for="CreatedByAdminId" value="1" />
        
        <!-- Config hidden fields for model binding -->
        <input type="hidden" name="Configs[0].MaxSpinsPerDay" id="MaxSpinsPerDay" class="config-input" value="5" />
        <input type="hidden" name="Configs[0].NumberOfSections" id="NumberOfSections" class="config-input" value="8" />
        <input type="hidden" name="Configs[0].GameStartDate" id="GameStartDate" class="config-input" />
        <input type="hidden" name="Configs[0].GameEndDate" id="GameEndDate" class="config-input" />
        <input type="hidden" name="Configs[0].IsActive" id="ConfigIsActive" class="config-input" value="true" />

        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <ul class="nav nav-tabs border-0 rounded-top-4 overflow-hidden" id="gameTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active fw-600 px-4 py-3" id="game-tab" data-bs-toggle="tab" data-bs-target="#game" type="button" role="tab">
                        <i class="fa-solid fa-gamepad me-2"></i> Game
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-600 px-4 py-3" id="config-tab" data-bs-toggle="tab" data-bs-target="#config" type="button" role="tab">
                        <i class="fa-solid fa-cog me-2"></i> Configuration
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-600 px-4 py-3" id="sections-tab" data-bs-toggle="tab" data-bs-target="#sections" type="button" role="tab">
                        <i class="fa-solid fa-layer-group me-2"></i> Sections
                    </button>
                </li>
            </ul>

            <div class="tab-content border-0 p-0">
                <div class="tab-pane fade show active p-5 bg-light" id="game" role="tabpanel">
                    <div class="row g-4">
                        <div class="col-md-8">
                            <label asp-for="GameName" class="form-label fw-600 fs-5"></label>
                            <input asp-for="GameName" class="form-control form-control-lg" data-val="true" data-val-required="Game Name is required." data-val-length="Game Name must be between 3 and 100 characters." data-val-length-min="3" data-val-length-max="100" />
                            <span asp-validation-for="GameName" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 form-group">
                            <label asp-for="IsActive" class="form-label fw-600">Status</label>
                            <div class="form-check mt-2">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                <label class="form-check-label fw-600" for="IsActive">
                                    Active Game
                                </label>
                            </div>
                        </div>
                        <div class="col-12 form-group">
                            <label asp-for="Description" class="form-label fw-600">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="4" data-val="true" data-val-length-max="500" data-val-length="Description cannot exceed 500 characters." ></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade p-5" id="config" role="tabpanel">
                    <div class="row g-4">
                        <div class="col-md-6 form-group">
                            <label class="form-label fw-600">Max Spins Per Day *</label>
                            <input type="number" class="form-control config-input" id="MaxSpinsPerDayVisible" min="1" max="100" value="5" data-val="true" data-val-required="Max spins per day is required." data-val-number="Must be a number." data-val-range="Must be between 1 and 100." data-val-range-min="1" data-val-range-max="100" />
                            <span class="text-danger field-error" data-field="maxspins"></span>
                        </div>
                        <div class="col-md-6 form-group">
                            <label class="form-label fw-600">Number of Sections *</label>
                            <input type="number" class="form-control config-input" id="NumberOfSectionsVisible" min="4" max="20" value="8" data-val="true" data-val-required="Number of sections is required." data-val-number="Must be a number." data-val-range="Must be between 4 and 20." data-val-range-min="4" data-val-range-max="20" />
                            <span class="text-danger field-error" data-field="numsections"></span>
                        </div>
                        <div class="col-md-6 form-group">
                            <label class="form-label fw-600">Game Start Date</label>
                            <input type="date" class="form-control config-input" id="GameStartDateVisible" data-val="true" data-val-date="Must be a valid date." />
                            <span class="text-danger field-error" data-field="startdate"></span>
                        </div>
                        <div class="col-md-6 form-group">
                            <label class="form-label fw-600">Game End Date *</label>
                            <input type="date" class="form-control config-input" id="GameEndDateVisible" data-val="true" data-val-required="End date is required." data-val-date="Must be a valid date." />
                            <span class="text-danger field-error" data-field="enddate"></span>
                        </div>
                        <div class="col-12 form-group">
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input config-input" id="ConfigActive" checked data-val="true" />
                                <label class="form-check-label fw-600" for="ConfigActive">
                                    Config Active
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade p-5" id="sections" role="tabpanel">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-800 mb-0">Wheel Sections <span class="text-danger">*</span> (Min 4)</h5>
                        <button type="button" class="btn btn-primary rounded-pill px-4 fw-600 shadow-sm" onclick="addSection()">
                            <i class="fa-solid fa-plus me-2"></i> Add Section
                        </button>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle rounded-3 overflow-hidden" id="sectionsTable">
                            <thead class="table-dark">
                                <tr>
                                    <th>#</th>
                                    <th>Section #</th>
                                    <th>Points (optional)</th>
                                    <th>Promotion ID (optional)</th>
                                    <th>Prize Text *</th>
                                    <th>Color</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="sectionsBody">
                                @foreach (var section in Model.Sections)
                                {
                                    <tr data-section-id="@section.SectionId">
                                        <td>@section.SectionNumber</td>
                                        <td>@section.SectionNumber</td>
                                        <td><input type="number" class="form-control points-input" value="@section.Points" min="0" /></td>
                                        <td><input type="number" class="form-control promo-input" value="@section.PromotionId" min="0" /></td>
                                        <td><input type="text" class="form-control text-input" value="@section.PrizeText" data-val="true" data-val-required="Prize text is required." /></td>
                                        <td><input type="color" class="form-control color-input" value="@section.Color" /></td>
                                        <td>
                                            <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteSection(this)">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div id="sectionsError" class="alert alert-danger mt-3" style="display:none;">
                        Please fix section errors and ensure at least 4 sections.
                    </div>
                </div>
            </div>

            <div class="card-footer bg-light border-0 pt-0 px-5 pb-4">
                <div class="d-flex justify-content-end gap-3">
                    <a href="@Url.Action("Index", "SpinGame")" class="btn btn-light rounded-pill px-5">Cancel</a>
                    <button type="submit" class="btn btn-primary rounded-pill px-5 fw-600 shadow-sm" id="saveBtn">
                        <i class="fa-solid fa-save me-2"></i> @(Model.GameId > 0 ? "Update" : "Create") Spin Game
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
let sectionCounter = @Model.Sections.Count || 0;

function addSection() {
    sectionCounter++;
    const tbody = document.getElementById('sectionsBody');
    const row = `
        <tr data-section-id="0">
            <td>${sectionCounter}</td>
            <td>${sectionCounter}</td>
            <td><input type="number" class="form-control points-input" value="0" min="0" /></td>
            <td><input type="number" class="form-control promo-input" value="" min="0" /></td>
            <td><input type="text" class="form-control text-input" value="Try Again" data-val="true" data-val-required="Prize text is required." /></td>
            <td><input type="color" class="form-control color-input" value="#3498db" /></td>
            <td>
                <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteSection(this)">
                    <i class="fa-solid fa-trash"></i>
                </button>
            </td>
        </tr>`;
    tbody.insertAdjacentHTML('beforeend', row);
    validateSections();
}

function deleteSection(btn) {
    if (confirm('Delete this section?')) {
        btn.closest('tr').remove();
        const rows = document.querySelectorAll('#sectionsBody tr');
        rows.forEach((row, index) => {
            row.cells[0].textContent = index + 1;
            row.cells[1].textContent = index + 1;
        });
        sectionCounter = rows.length;
        validateSections();
    }
}

function validateSections() {
    const rows = document.querySelectorAll('#sectionsBody tr');
    let valid = rows.length >= 4;
    rows.forEach(row => {
        const prizeInput = row.querySelector('.text-input');
        if (!prizeInput.value.trim()) {
            valid = false;
            row.classList.add('table-danger');
        } else {
            row.classList.remove('table-danger');
        }
    });
    const errorDiv = document.getElementById('sectionsError');
    errorDiv.style.display = valid ? 'none' : 'block';
    return valid;
}

function syncConfigFields() {
    document.getElementById('MaxSpinsPerDay').value = document.getElementById('MaxSpinsPerDayVisible').value;
    document.getElementById('NumberOfSections').value = document.getElementById('NumberOfSectionsVisible').value;
    document.getElementById('GameStartDate').value = document.getElementById('GameStartDateVisible').value;
    document.getElementById('GameEndDate').value = document.getElementById('GameEndDateVisible').value;
    document.getElementById('ConfigIsActive').value = document.getElementById('ConfigActive').checked ? 'true' : 'false';
}

$(document).ready(function() {
    $.validator.addMethod('dateCompare', function(value, element, params) {
        const startDate = new Date($(params.start).val());
        const endDate = new Date(value);
        return endDate >= startDate;
    }, 'End date must be after or same as start date.');

    const validator = $('#spinGameForm').validate({
        rules: {
            'Configs[0].GameEndDate': {
                dateCompare: { start: '#GameStartDateVisible' }
            }
        },
        errorClass: 'text-danger',
        validClass: 'text-success',
        errorPlacement: function(error, element) {
            error.insertAfter(element);
        },
        invalidHandler: function(event, validator) {
            let firstTab = null;
            validator.errorList.forEach(err => {
                const field = $(err.element);
                const tabPane = field.closest('.tab-pane');
                if (tabPane.length && !firstTab) {
                    const tabId = tabPane.attr('id');
                    $(`[data-bs-target="#${tabId}"]`).tab('show');
                    firstTab = true;
                }
            });
        },
        submitHandler: function(form) {
            syncConfigFields();
            if (validateSections()) {
                form.submit();
            } else {
                $('#sections-tab').tab('show');
                return false;
            }
        }
    });

    $('.config-input').on('change input', syncConfigFields);

    $('#NumberOfSectionsVisible').on('change', function() {
        const num = parseInt(this.value) || 8;
        const tbody = document.getElementById('sectionsBody');
        while (tbody.children.length < num) addSection();
        while (tbody.children.length > num && tbody.children.length > 4) {
            tbody.removeChild(tbody.lastChild);
        }
        sectionCounter = tbody.children.length;
    });

    if (document.getElementById('sectionsBody').children.length > 0) {
        validateSections();
    }

    $(document).on('input', '.points-input, .promo-input', function() {
        if (parseInt(this.value) < 0) this.value = 0;
    });
});
let sectionCounter = @Model.Sections.Count || 0;

function addSection() {
    sectionCounter++;
    const tbody = document.getElementById('sectionsBody');
    const row = `
        <tr data-section-id="0">
            <td>${sectionCounter}</td>
            <td>${sectionCounter}</td>
            <td><input type="number" class="form-control points-input" value="0" min="0" /></td>
            <td><input type="number" class="form-control promo-input" value="" min="0" /></td>
            <td><input type="text" class="form-control text-input" value="Try Again" data-val="true" data-val-required="Prize text is required." /></td>
            <td><input type="color" class="form-control color-input" value="#3498db" /></td>
            <td>
                <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteSection(this)">
                    <i class="fa-solid fa-trash"></i>
                </button>
            </td>
        </tr>`;
    tbody.insertAdjacentHTML('beforeend', row);
    // Revalidate sections after add
    validateSections();
}

function deleteSection(btn) {
    if (confirm('Delete this section?')) {
        btn.closest('tr').remove();
        const rows = document.querySelectorAll('#sectionsBody tr');
        rows.forEach((row, index) => {
            row.cells[0].textContent = index + 1;
            row.cells[1].textContent = index + 1;
        });
        sectionCounter = rows.length;
        validateSections();
    }
}

function validateSections() {
    const rows = document.querySelectorAll('#sectionsBody tr');
    let valid = rows.length >= 4;
    rows.forEach(row => {
        const prizeInput = row.querySelector('.text-input');

        if (!prizeInput.value.trim()) {
            valid = false;
            row.classList.add('table-danger');
        } else {
            row.classList.remove('table-danger');
        }
    });
    const errorDiv = document.getElementById('sectionsError');
    if (!valid) {
        errorDiv.style.display = 'block';
    } else {
        errorDiv.style.display = 'none';
    }
    return valid;
}

function syncConfigFields() {
    document.getElementById('MaxSpinsPerDay').value = document.getElementById('MaxSpinsPerDayVisible').value;
    document.getElementById('NumberOfSections').value = document.getElementById('NumberOfSectionsVisible').value;
    document.getElementById('GameStartDate').value = document.getElementById('GameStartDateVisible').value;
    document.getElementById('GameEndDate').value = document.getElementById('GameEndDateVisible').value;
    document.getElementById('ConfigIsActive').value = document.getElementById('ConfigActive').checked;
}

$(document).ready(function() {
    // Custom validator methods
    $.validator.addMethod('dateCompare', function(value, element, params) {
        const startDate = new Date($(params.start).val());
        const endDate = new Date(value);
        return endDate >= startDate;
    }, 'End date must be after or same as start date.');

    // Initialize validator
    const validator = $('#spinGameForm').validate({
        rules: {
            'Configs[0].GameEndDate': {
                dateCompare: { start: '#GameStartDateVisible' }
            }
        },
        messages: {},
        errorClass: 'text-danger',
        validClass: 'text-success',
        errorPlacement: function(error, element) {
            error.insertAfter(element);
        },
        invalidHandler: function(event, validator) {
            const invalidTabs = {};
            validator.errorList.forEach(err => {
                const field = $(err.element);
                const tabId = field.closest('.tab-pane').attr('id');
                if (tabId) invalidTabs[tabId] = true;
            });
            // Activate first invalid tab
            Object.keys(invalidTabs)[0] && $(`#${Object.keys(invalidTabs)[0]}-tab`).tab('show');
        },
        submitHandler: function(form) {
            syncConfigFields();
            if (validateSections()) {
                form.submit();
            } else {
                $('#sections-tab').tab('show');
                return false;
            }
        }
    });

    // Event listeners for real-time sync and validation
    $('.config-input').on('change input', function() {
        syncConfigFields();
    });

    $('#NumberOfSectionsVisible').on('change', function() {
        const num = parseInt(this.value) || 8;
        const tbody = document.getElementById('sectionsBody');
        while (tbody.children.length < num) addSection();
        while (tbody.children.length > num && tbody.children.length > 4) {  // Don't delete below min
            tbody.removeChild(tbody.lastChild);
        }
        sectionCounter = tbody.children.length;
    });

    // Initial sections validation
    if (document.getElementById('sectionsBody').children.length > 0) {
        validateSections();
    }

    // Points and promo number validation (basic HTML5)
    $(document).on('input', '.points-input, .promo-input', function() {
        if (this.value < 0) this.value = 0;
    });
});
    </script>
}

