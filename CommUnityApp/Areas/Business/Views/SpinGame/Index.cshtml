@model IEnumerable<CommUnityApp.ApplicationCore.Models.SpinGameDto>
@{
    ViewData["Title"] = "My Spin Games";
    Layout = "_BusinessLayout";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-800 mb-1">My Spin Games</h2>
            <p class="text-muted">Manage your spin wheel game campaigns.</p>
        </div>
        <a href="@Url.Action("Create", "SpinGame")" class="btn btn-primary rounded-pill px-4 fw-600 shadow-sm">
            <i class="fa-solid fa-plus me-2"></i> Create New Spin Game
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success rounded-4 shadow-sm mb-4 border-0 bg-success bg-opacity-10 text-success">
            <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
        </div>
    }

    <div class="table-responsive">
        <table class="table custom-table align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-4 border-0">Game Info</th>
                    <th class="border-0">Status</th>
                    <th class="border-0 pe-4 text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var game in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div>
                                    <div class="fw-700 text-dark">@game.GameName</div>
                                    <div class="text-muted small">@game.Description</div>
                                </div>
                            </td>
                            <td>
                                <span class="badge @(game.IsActive ? "bg-success-subtle text-success" : "bg-secondary-subtle text-muted") rounded-pill px-3"> 
                                    @(game.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td class="pe-4 text-end">
                                <div class="dropdown">
                                    <button class="btn btn-icon btn-light rounded-circle" data-bs-toggle="dropdown">
                                        <i class="fa-solid fa-ellipsis-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-3">
                                        <li><a class="dropdown-item py-2" href="@Url.Action("Create", "SpinGame", new { spinGameId = game.GameId })">
                                            <i class="fa-solid fa-pen-to-square me-2 text-info"></i> Edit
                                        </a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item py-2 text-danger" href="#" onclick="deleteGame(@game.GameId)">
                                            <i class="fa-solid fa-trash-can me-2"></i> Delete
                                        </a></li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="py-5 text-center">
                            <div class="opacity-40 mb-3">
                                <i class="fa-solid fa-dice fa-3x"></i>
                            </div>
                            <h5 class="fw-700 text-muted">No Spin Games found</h5>
                            <p class="text-muted mb-4">Create your first spin wheel game.</p>
                            <a href="@Url.Action("Create", "SpinGame")" class="btn btn-primary rounded-pill px-4 fw-600">Create New Spin Game</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
function deleteGame(id) {
    if (confirm('Are you sure you want to delete this spin game?')) {
        fetch(`/Business/SpinGame/Delete/${id}`, { method: 'POST' })
            .then(response => response.json())
            .then(data => {
                if (data.resultId > 0) location.reload();
                else alert(data.resultMessage);
            });
    }
}
</script>

<style>
/* Reuse existing styles from Game/Index.cshtml */
.custom-table { /* same as Game */ }
</style>

