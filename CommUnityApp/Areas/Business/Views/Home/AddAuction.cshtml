    <div class="form-wrapper">

        <h1>Bid Item Enrolment Form</h1>
        <p class="subtitle">Seller Side – Submit item for auction review</p>

        <form id="auctionForm">

            <input type="hidden" id="BusinessId" value="1">

            <!-- ✅ UserId comes from Cookie -->
            <input type="hidden" id="UserId" value="@userId">

            <input type="hidden" id="AuctionStatus" value="1">
            <input type="hidden" id="CreatedBy" value="admin">

            <!-- ✅ REST OF YOUR UI EXACTLY SAME -->

