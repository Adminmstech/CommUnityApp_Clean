                    <div>
                      
                        <h2>1.Item Basic Details</h2>
                    </div>
                </div>
                <div class="grid-2">
                    <div class="field">
                        <label>Item Title<span>*</span></label>
                        <input type="text" id="ItemTitle" required>
                    </div>
                    <div class="field">
                        <label>Item Categories<span>*</span></label>
                        <select id="ItemTypeId" required>
                            <option value="">Loading categories...</option>
                        </select>
                    </div>
                </div>
                <div class="field">
                    <label>Item Description<span>*</span></label>
                    <textarea id="ItemDescription" rows="5" required></textarea>
                </div>
            </section>

            <section>
                <div class="section-header">
                    <div class="section-icon">
                        <i class="fa-solid fa-tag"></i>
                    </div>

                    <div>
                       
                        <h2>2.Item Condition<span>*</span></h2>
                    </div>
                </div>
              
                <div class="field">
                    <textarea id="ItemCondition" rows="5" required></textarea>
