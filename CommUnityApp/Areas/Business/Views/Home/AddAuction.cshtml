                    </div>
                </div>
                
                <div class="grid-2">
                    <div class="field">
                        <label>Start Date<span>*</span></label>
                        <input type="datetime-local" id="RegistrationstartDate" required>
                    </div>
                    <div class="field">
                        <label>End Date<span>*</span></label>
                        <input type="datetime-local" id="RegistrationEndDate" required>
                    </div>
                </div>
                <div class="duration-display" id="RegistrationDurationDisplay"></div>

            </section>

            <section>
                <div class="section-header">
                    <div class="section-icon">
                        <i class="fa-solid fa-location-dot"></i>
                    </div>

                    <div>
                      
