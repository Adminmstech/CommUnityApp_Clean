@using System.Security.Claims

@{
    ViewData["Title"] = "Add / Edit Auction";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var userId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

    var auctionId = Context.Request.Query["AuctionId"].ToString();
}

<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css"
          rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css"
          rel="stylesheet">

    <style>

        body {
            background: #f5f6fa;
        }

        .card {
            border: none;
            border-radius: 15px;
            box-shadow: 0 5px 20px rgba(0,0,0,.08);
        }

        .card-header {
            background: #fff;
            font-weight: 700;
            font-size: 18px;
        }

        .section-title {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 20px;
            color: #444;
        }

        .required {
            color: red;
        }

        .image-preview {
            width: 150px;
            height: 150px;
            object-fit: cover;
            border-radius: 10px;
            border: 1px solid #ddd;
            margin-right: 10px;
            margin-bottom: 10px;
        }

        .old-image {
            position: relative;
            display: inline-block;
        }

        .remove-old {
            position: absolute;
            top: 5px;
            right: 5px;
            background: red;
            color: white;
            border: none;
            border-radius: 50%;
            width: 25px;
            height: 25px;
        }

        .form-control,
        .form-select {
            height: 48px;
        }

        textarea.form-control {
            height: auto;
        }

        .switch {
            margin-top: 40px;
        }

        .btn-save {
            width: 180px;
            height: 50px;
            font-size: 18px;
        }
    </style>

</head>

<body>

    <div class="container py-4">

        <div class="card">

            <div class="card-header d-flex justify-content-between align-items-center">

                <div>

                    <i class="fa-solid fa-gavel"></i>

                    <span id="pageTitle">

                        Add Auction

                    </span>

                </div>

                <a href="/Business/Home/Auctions"
                   class="btn btn-secondary">

                    Back

                </a>

            </div>

            <div class="card-body">

                <form id="auctionForm">

                    <input type="hidden"
                           id="AuctionId"
                           value="@auctionId" />

                    <input type="hidden"
                           id="BusinessId"
                           value="1" />

                    <input type="hidden"
                           id="UserId"
                           value="@userId" />

                    <input type="hidden"
                           id="AuctionStatus"
                           value="1" />

                    <input type="hidden"
                           id="CreatedBy"
                           value="@userId" />

                    
                    <!-- ============================= -->
                    <!-- Item Basic Details -->
                    <!-- ============================= -->

                    <div class="card mb-4">

                        <div class="card-header bg-primary text-white">
                            <i class="fa-solid fa-box"></i>
                            Item Details
                        </div>

                        <div class="card-body">

                            <div class="row">

                                <div class="col-md-6 mb-3">

                                    <label class="form-label">
                                        Item Title
                                        <span class="required">*</span>
                                    </label>

                                    <input type="text"
                                           class="form-control"
                                           id="ItemTitle"
                                           maxlength="200"
                                           placeholder="Enter Item Title">

                                </div>

                                <div class="col-md-6 mb-3">

                                    <label class="form-label">
                                        Item Category
                                        <span class="required">*</span>
                                    </label>

                                    <select id="ItemTypeId"
                                            class="form-select">

                                        <option value="">Loading...</option>

                                    </select>

                                </div>

                            </div>

                            <div class="row">

                                <div class="col-md-12 mb-3">

                                    <label class="form-label">
                                        Item Description
                                        <span class="required">*</span>
                                    </label>

                                    <textarea id="ItemDescription"
                                              class="form-control"
                                              rows="5"
                                              maxlength="2000"
                                              placeholder="Enter Item Description"></textarea>

                                </div>

                            </div>

                            <div class="row">

                                <div class="col-md-12 mb-3">

                                    <label class="form-label">
                                        Item Condition
                                        <span class="required">*</span>
                                    </label>

                                    <textarea id="ItemCondition"
                                              class="form-control"
                                              rows="4"
                                              maxlength="1000"
                                              placeholder="Example: Excellent Condition"></textarea>

                                </div>

                            </div>

                        </div>

                    </div>

                    <!-- ============================= -->
                    <!-- Pricing -->
                    <!-- ============================= -->

                    <div class="card mb-4">

                        <div class="card-header bg-success text-white">

                            <i class="fa-solid fa-indian-rupee-sign"></i>

                            Pricing Details

                        </div>

                        <div class="card-body">

                            <div class="row">

                                <div class="col-md-4 mb-3">

                                    <label class="form-label">

                                        Reserve Price

                                        <span class="required">*</span>

                                    </label>

                                    <input type="number"
                                           id="ReservePrice"
                                           class="form-control"
                                           min="1">

                                </div>

                                <div class="col-md-4 mb-3">

                                    <label class="form-label">

                                        Bid Increment

                                        <span class="required">*</span>

                                    </label>

                                    <input type="number"
                                           id="PriceIncrement"
                                           class="form-control"
                                           min="1">

                                </div>

                                <div class="col-md-4 mb-3">

                                    <label class="form-label">

                                        Minimum Deposit

                                        <span class="required">*</span>

                                    </label>

                                    <input type="number"
                                           id="MinDeposite"
                                           class="form-control"
                                           min="0">

                                </div>

                            </div>

                        </div>

                    </div>

                    <!-- ============================= -->
                    <!-- Registration Settings -->
                    <!-- ============================= -->

                    <div class="card mb-4">

                        <div class="card-header bg-warning">

                            <i class="fa-solid fa-user-check"></i>

                            Registration Settings

                        </div>

                        <div class="card-body">

                            <div class="row">

                                <div class="col-md-4">

                                    <label class="form-label">

                                        Registration Required

                                    </label>

                                    <div class="form-check form-switch mt-2">

                                        <input class="form-check-input"
                                               type="checkbox"
                                               id="RegistrationRequired">

                                        <label class="form-check-label"
                                               for="RegistrationRequired">

                                            Enable Registration

                                        </label>

                                    </div>

                                </div>

                                <div class="col-md-4">

                                    <label class="form-label">

                                        Registration Start

                                    </label>

                                    <input type="datetime-local"
                                           id="RegistrationStartDate"
                                           class="form-control">

                                </div>

                                <div class="col-md-4">

                                    <label class="form-label">

                                        Registration End

                                    </label>

                                    <input type="datetime-local"
                                           id="RegistrationEndDate"
                                           class="form-control">

                                </div>

                            </div>

                        </div>

                    </div>
                    <!-- ============================= -->
                    <!-- Images -->
                    <!-- ============================= -->

                    <div class="card mb-4">

                        <div class="card-header bg-info text-white">

                            <i class="fa-solid fa-images"></i>

                            Auction Images

                        </div>

                        <div class="card-body">

                            <div class="mb-3">

                                <label class="form-label">

                                    Upload Images

                                    <span class="required">*</span>

                                </label>

                                <input type="file"
                                       id="Images"
                                       class="form-control"
                                       accept="image/*"
                                       multiple>

                                <small class="text-muted">

                                    First selected image will be Primary Image.

                                </small>

                            </div>

                            <hr />

                            <h6>Existing Images</h6>

                            <div id="oldImagesContainer"
                                 class="d-flex flex-wrap">
                            </div>

                            <hr />

                            <h6>New Image Preview</h6>

                            <div id="previewContainer"
                                 class="d-flex flex-wrap">
                            </div>

                        </div>

                    </div>

                    <!-- ============================= -->
                    <!-- Delivery & Location -->
                    <!-- ============================= -->

                    <div class="card mb-4">

                        <div class="card-header bg-secondary text-white">

                            <i class="fa-solid fa-location-dot"></i>

                            Delivery & Location

                        </div>

                        <div class="card-body">

                            <div class="row">

                                <div class="col-md-6 mb-3">

                                    <label class="form-label">

                                        Item Location

                                        <span class="required">*</span>

                                    </label>

                                    <input type="text"
                                           id="ItemLocation"
                                           class="form-control"
                                           placeholder="Enter Item Location">

                                </div>

                                <div class="col-md-6 mb-3">

                                    <label class="form-label">

                                        Delivery Method

                                        <span class="required">*</span>

                                    </label>

                                    <select id="DeleveryMethodId"
                                            class="form-select">

                                        <option value="">Select Delivery</option>

                                        <option value="1">
                                            Pickup Only
                                        </option>

                                        <option value="2">
                                            Local Delivery
                                        </option>

                                        <option value="3">
                                            Pickup + Delivery
                                        </option>

                                    </select>

                                </div>

                            </div>

                        </div>

                    </div>

                    <!-- ============================= -->
                    <!-- Existing Image Template -->
                    <!-- ============================= -->

                    <template id="oldImageTemplate">

                        <div class="old-image me-3 mb-3">

                            <img class="image-preview old-preview" />

                            <button type="button"
                                    class="remove-old">

                                <i class="fa fa-times"></i>

                            </button>

                        </div>

                    </template>

                    <!-- ============================= -->
                    <!-- New Image Template -->
                    <!-- ============================= -->

                    <template id="newImageTemplate">

                        <div class="me-3 mb-3 text-center">

                            <img class="image-preview new-preview" />

                            <div class="form-check mt-2">

                                <input class="form-check-input primary-image"
                                       type="radio"
                                       name="PrimaryImage">

                                <label class="form-check-label">

                                    Primary

                                </label>

                            </div>

                        </div>

                    </template>
                    <!-- ========================================== -->
                    <!-- Auction Schedule -->
                    <!-- ========================================== -->

                    <div class="card mb-4">

                        <div class="card-header bg-dark text-white">

                            <i class="fa-solid fa-clock"></i>

                            Auction Schedule

                        </div>

                        <div class="card-body">

                            <div class="row">

                                <div class="col-md-4 mb-3">

                                    <label class="form-label">

                                        Start Time

                                        <span class="required">*</span>

                                    </label>

                                    <input type="datetime-local"
                                           id="StartTime"
                                           class="form-control">

                                </div>

                                <div class="col-md-4 mb-3">

                                    <label class="form-label">

                                        End Time

                                        <span class="required">*</span>

                                    </label>

                                    <input type="datetime-local"
                                           id="EndTime"
                                           class="form-control">

                                </div>

                                <div class="col-md-4 mb-3">

                                    <label class="form-label">

                                        Auction Duration

                                    </label>

                                    <input type="text"
                                           id="Duration"
                                           class="form-control"
                                           readonly>

                                </div>

                            </div>

                            @* <div class="row mt-2">

                                <div class="col-md-6">

                                    <select id="TimeZoneId" class="form-select">
                                        <option value="India Standard Time">India Standard Time (UTC+05:30)</option>
                                        <option value="AUS Eastern Standard Time">Australia Eastern (UTC+10:00)</option>
                                        <option value="GMT Standard Time">London (UTC+00:00)</option>
                                        <option value="Eastern Standard Time">US Eastern (UTC-05:00)</option>
                                        <option value="Central Standard Time">US Central (UTC-06:00)</option>
                                        <option value="Mountain Standard Time">US Mountain (UTC-07:00)</option>
                                        <option value="Pacific Standard Time">US Pacific (UTC-08:00)</option>
                                    </select>

                                </div>

                            </div> *@

                        </div>

                    </div>

                    <!-- ========================================== -->
                    <!-- Submit -->
                    <!-- ========================================== -->

                    <div class="card">

                        <div class="card-body text-center">

                            <button type="button"
                                    id="btnSave"
                                    class="btn btn-success btn-lg px-5">

                                <i class="fa-solid fa-floppy-disk"></i>

                                Save Auction

                            </button>

                            <button type="button"
                                    id="btnUpdate"
                                    class="btn btn-warning btn-lg px-5 d-none">

                                <i class="fa-solid fa-pen"></i>

                                Update Auction

                            </button>

                            <button type="reset"
                                    class="btn btn-secondary btn-lg px-5">

                                <i class="fa-solid fa-rotate-left"></i>

                                Reset

                            </button>

                        </div>

                    </div>

                </form>

            </div>

        </div>

    </div>

    <!-- ========================================== -->
    <!-- Loading Modal -->
    <!-- ========================================== -->

    <div class="modal fade"
         id="loadingModal"
         data-bs-backdrop="static"
         data-bs-keyboard="false"
         tabindex="-1">

        <div class="modal-dialog modal-dialog-centered">

            <div class="modal-content">

                <div class="modal-body text-center p-5">

                    <div class="spinner-border text-primary mb-3"
                         style="width:4rem;height:4rem;">
                    </div>

                    <h5>

                        Please wait...

                    </h5>

                    <p>

                        Saving Auction

                    </p>

                </div>

            </div>

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script>

        //=========================================================
        // Global Variables
        //=========================================================

        const API_BASE = "/api/Auction";

        let auctionId = 0;

        let existingImages = [];

        let removedImages = [];

        let selectedFiles = [];

        let loadingModal = null;

        //=========================================================
        // Document Ready
        //=========================================================

        $(document).ready(async function () {

            auctionId = $("#AuctionId").val() || 0;

                  

            registerEvents();

            await loadCategories();

            if (parseInt(auctionId) > 0) {

                $("#pageTitle").text("Edit Auction");

                $("#btnSave").addClass("d-none");

                $("#btnUpdate").removeClass("d-none");

                await loadAuction();

            }
            else {

                $("#pageTitle").text("Add Auction");

            }

        });

        //=========================================================
        // Register Events
        //=========================================================

        function registerEvents() {

            $("#StartTime").on("change", calculateDuration);

            $("#EndTime").on("change", calculateDuration);

            $("#Images").on("change", previewImages);

            $("#RegistrationRequired").on("change", function () {

                toggleRegistrationFields();

            });

            $("#btnSave").on("click", function () {

                saveAuction(false);

            });

            $("#btnUpdate").on("click", function () {

                saveAuction(true);

            });

        }

        //=========================================================
        // Enable / Disable Registration Dates
        //=========================================================

        function toggleRegistrationFields() {

            let enabled = $("#RegistrationRequired").is(":checked");

            $("#RegistrationStartDate").prop("disabled", !enabled);

            $("#RegistrationEndDate").prop("disabled", !enabled);

            if (!enabled) {

                $("#RegistrationStartDate").val("");

                $("#RegistrationEndDate").val("");

            }

        }

       

        //=========================================================
        // Load Categories
        //=========================================================

        async function loadCategories() {

            try {

                const response = await fetch(API_BASE + "/Get_ItemType");

                if (!response.ok)
                    throw new Error();

                const data = await response.json();

                $("#ItemTypeId").empty();

                $("#ItemTypeId").append(
                    `<option value="">Select Category</option>`
                );

                data.forEach(function (item) {

                    if (item.isActive) {

                        $("#ItemTypeId").append(

                            `<option value="${item.itemTypeId}">
                                ${item.itemTypeName}
                            </option>`

                        );

                    }

                });

            }
            catch {

                Swal.fire(
                    "Error",
                    "Unable to load categories.",
                    "error"
                );

            }

        }

        //=========================================================
        // Calculate Auction Duration
        //=========================================================

        function calculateDuration() {

            let start = $("#StartTime").val();

            let end = $("#EndTime").val();

            if (start === "" || end === "") {

                $("#Duration").val("");

                return;

            }

            let s = new Date(start);

            let e = new Date(end);

            if (e <= s) {

                $("#Duration").val("");

                Swal.fire(
                    "Warning",
                    "End Time must be greater than Start Time",
                    "warning"
                );

                return;

            }

            let diff = e - s;

            let totalMinutes = Math.floor(diff / 60000);

            let days = Math.floor(totalMinutes / 1440);

            totalMinutes %= 1440;

            let hours = Math.floor(totalMinutes / 60);

            let minutes = totalMinutes % 60;

            let text = "";

            if (days > 0)
                text += days + " Day ";

            if (hours > 0)
                text += hours + " Hour ";

            if (minutes > 0)
                text += minutes + " Minute";

            $("#Duration").val(text);

        }

        //=========================================================
        // Loading Popup
        //=========================================================

        function showLoading() {

            loadingModal = new bootstrap.Modal(
                document.getElementById("loadingModal")
            );

            loadingModal.show();

        }

        function hideLoading() {

            if (loadingModal != null)
                loadingModal.hide();

        }
        //=========================================================
        // Load Auction Details
        //=========================================================

        async function loadAuction() {

            try {

                showLoading();

                const response = await fetch(

                    API_BASE +
                    "/Get_AuctionByAuctionId?AuctionId=" +
                    auctionId

                );

                if (!response.ok) {

                    hideLoading();

                    Swal.fire(
                        "Error",
                        "Unable to load auction.",
                        "error"
                    );

                    return;
                }

                const result = await response.json();

                if (!result || result.length == 0) {

                    hideLoading();

                    Swal.fire(
                        "Error",
                        "Auction not found.",
                        "error"
                    );

                    return;
                }

                let a = result[0];

                //--------------------------------------------------
                // Hidden Fields
                //--------------------------------------------------

                $("#AuctionId").val(a.auctionId);

                $("#BusinessId").val(a.businessId);

                $("#UserId").val(a.userId);

                $("#AuctionStatus").val(a.auctionStatus);

                $("#CreatedBy").val(a.createdBy);

                //--------------------------------------------------
                // Item Details
                //--------------------------------------------------

                $("#ItemTitle").val(a.itemTitle);

                $("#ItemTypeId").val(a.itemTypeId);

                $("#ItemDescription").val(a.itemDescription);

                $("#ItemCondition").val(a.itemCondition);

                //--------------------------------------------------
                // Pricing
                //--------------------------------------------------

                $("#ReservePrice").val(a.reservePrice);

                $("#PriceIncrement").val(a.priceIncrement);

                $("#MinDeposite").val(a.minDeposite);

                //--------------------------------------------------
                // Schedule
                //--------------------------------------------------

                $("#StartTime").val(formatDate(a.startTime));

                $("#EndTime").val(formatDate(a.endTime));

                calculateDuration();

                //--------------------------------------------------
                // Registration
                //--------------------------------------------------

                $("#RegistrationRequired")
                    .prop("checked", a.registrationRequired);

                toggleRegistrationFields();

                if (a.registrationStartDate != null) {

                    $("#RegistrationStartDate")
                        .val(formatDate(a.registrationStartDate));

                }

                if (a.registrationEndDate != null) {

                    $("#RegistrationEndDate")
                        .val(formatDate(a.registrationEndDate));

                }

                //--------------------------------------------------
                // Delivery
                //--------------------------------------------------

                $("#ItemLocation").val(a.itemLocation);

                $("#DeleveryMethodId").val(a.deleveryMethodId);

                // //--------------------------------------------------
                // // TimeZone
                // //--------------------------------------------------

                // if (a.timeZoneId != null &&
                //     a.timeZoneId != "") {

                //     $("#TimeZoneId").val(a.timeZoneId);

                //     $("#TimeZoneDisplay").val(a.timeZoneId);

                // }

                //--------------------------------------------------
                // Existing Images
                //--------------------------------------------------

                existingImages = [];

                removedImages = [];

                $("#oldImagesContainer").empty();

                if (a.images != null &&
                    a.images.length > 0) {

                    a.images.forEach(function (img) {

                        existingImages.push(img);

                        appendOldImage(img);

                    });

                }

                hideLoading();

            }

            catch (ex) {

                hideLoading();

                console.log(ex);

                Swal.fire(
                    "Error",
                    "Unexpected error occurred.",
                    "error"
                );

            }

        }

        //=========================================================
        // Existing Image Card
        //=========================================================

        function appendOldImage(img) {

            let imageUrl = "/" + img.imageUrl;

            let html = `

            <div class="old-image me-3 mb-3"

                 data-id="${img.auctionItemImageId}">

                <img

                    src="${imageUrl}"

                    class="image-preview">

                <button

                    type="button"

                    class="btn btn-danger btn-sm remove-old">

                    <i class="fa fa-trash"></i>

                </button>

            </div>`;

            $("#oldImagesContainer").append(html);

        }

        //=========================================================
        // Remove Existing Image
        //=========================================================

        $(document).on("click",
            ".remove-old",
            function () {

                let card = $(this).closest(".old-image");

                let id = card.data("id");

                removedImages.push(id);

                card.remove();

            });

        //=========================================================
        // Format DateTime
        //=========================================================

        function formatDate(date) {

            if (!date)
                return "";

            let d = new Date(date);

            let yyyy = d.getFullYear();

            let MM = String(
                d.getMonth() + 1
            ).padStart(2, '0');

            let dd = String(
                d.getDate()
            ).padStart(2, '0');

            let hh = String(
                d.getHours()
            ).padStart(2, '0');

            let mm = String(
                d.getMinutes()
            ).padStart(2, '0');

            return `${yyyy}-${MM}-${dd}T${hh}:${mm}`;

        }
        //=========================================================
        // Preview Selected Images
        //=========================================================

        function previewImages() {

            $("#previewContainer").empty();

            selectedFiles = [];

            const files = document.getElementById("Images").files;

            if (!files || files.length === 0)
                return;

            Array.from(files).forEach(function (file, index) {

                selectedFiles.push(file);

                const reader = new FileReader();

                reader.onload = function (e) {

                    let html = `

                    <div class="me-3 mb-3 text-center">

                        <img src="${e.target.result}"
                             class="image-preview"/>

                        <div class="form-check mt-2">

                            <input class="form-check-input primary-image"
                                   type="radio"
                                   name="PrimaryImage"
                                   value="${index}"
                                   ${index == 0 ? "checked" : ""}>

                            <label class="form-check-label">

                                Primary

                            </label>

                        </div>

                    </div>`;

                    $("#previewContainer").append(html);

                };

                reader.readAsDataURL(file);

            });

        }

        //=========================================================
        // Convert File To Base64
        //=========================================================

        function fileToBase64(file) {

            return new Promise((resolve, reject) => {

                const reader = new FileReader();

                reader.readAsDataURL(file);

                reader.onload = () => resolve(reader.result);

                reader.onerror = error => reject(error);

            });

        }

        //=========================================================
        // Validate Auction
        //=========================================================

        function validateAuction() {

            if ($("#ItemTitle").val().trim() === "") {

                Swal.fire("Validation", "Enter Item Title", "warning");

                return false;

            }

            if ($("#ItemTypeId").val() === "") {

                Swal.fire("Validation", "Select Category", "warning");

                return false;

            }

            if ($("#ReservePrice").val() === "") {

                Swal.fire("Validation", "Enter Reserve Price", "warning");

                return false;

            }

            if ($("#PriceIncrement").val() === "") {

                Swal.fire("Validation", "Enter Price Increment", "warning");

                return false;

            }

            if ($("#MinDeposite").val() === "") {

                Swal.fire("Validation", "Enter Minimum Deposit", "warning");

                return false;

            }

            if ($("#StartTime").val() === "") {

                Swal.fire("Validation", "Select Start Time", "warning");

                return false;

            }

            if ($("#EndTime").val() === "") {

                Swal.fire("Validation", "Select End Time", "warning");

                return false;

            }

            if ($("#ItemLocation").val().trim() === "") {

                Swal.fire("Validation", "Enter Item Location", "warning");

                return false;

            }

            if ($("#DeleveryMethodId").val() === "") {

                Swal.fire("Validation", "Select Delivery Method", "warning");

                return false;

            }

            if ($("#RegistrationRequired").is(":checked")) {

                if ($("#RegistrationStartDate").val() === "") {

                    Swal.fire("Validation",
                        "Select Registration Start Date",
                        "warning");

                    return false;

                }

                if ($("#RegistrationEndDate").val() === "") {

                    Swal.fire("Validation",
                        "Select Registration End Date",
                        "warning");

                    return false;

                }

            }

            return true;

        }

        //=========================================================
        // Build Images Collection
        //=========================================================

        async function buildImages() {

            let images = [];

            // User didn't choose new images
            // Existing images remain unchanged
            if (selectedFiles.length === 0)
                return images;

            let primaryIndex = parseInt(

                $(".primary-image:checked").val() ?? 0

            );

            for (let i = 0; i < selectedFiles.length; i++) {

                let base64 = await fileToBase64(selectedFiles[i]);

                images.push({

                    imageBase64: base64,

                    isPrimary: i === primaryIndex

                });

            }

            return images;

        }
        //=========================================================
        // Save / Update Auction
        //=========================================================

        async function saveAuction(isUpdate) {

            if (!validateAuction())
                return;

            try {

                showLoading();

                let images = await buildImages();

                const request = {

                    auction: {

                        auctionId: parseInt($("#AuctionId").val() || 0),

                        businessId: $("#BusinessId").val()? parseInt($("#BusinessId").val()): null,

                        userId: $("#UserId").val() ? $("#UserId").val(): null,

                        itemTypeId: parseInt($("#ItemTypeId").val()),

                        itemTitle: $("#ItemTitle").val().trim(),

                        itemDescription: $("#ItemDescription").val().trim(),

                        itemCondition: $("#ItemCondition").val().trim(),

                        reservePrice: parseFloat($("#ReservePrice").val()),

                        priceIncrement: parseFloat($("#PriceIncrement").val()),

                        minDeposite: parseFloat($("#MinDeposite").val()),

                        startTime: $("#StartTime").val(),

                        endTime: $("#EndTime").val(),

                       registrationRequired: $("#RegistrationRequired").is(":checked") ? 1 : 0,

                        registrationStartDate:
                            $("#RegistrationStartDate").val(),

                        registrationEndDate:
                            $("#RegistrationEndDate").val(),

                        itemLocation:
                            $("#ItemLocation").val().trim(),

                        deleveryMethodId:
                            parseInt($("#DeleveryMethodId").val()),

                        auctionStatus:
                            parseInt($("#AuctionStatus").val()),

                        createdBy:
                            $("#CreatedBy").val(),

                        

                    },

                    images: images

                };

                const response = await fetch(

                    API_BASE + "/UploadAndUpdateAuction",

                    {

                        method: "POST",

                        headers: {

                            "Content-Type": "application/json"

                        },

                        body: JSON.stringify(request)

                    }

                );

                const result = await response.json();

                hideLoading();

                if (response.ok && result.success) {

                    Swal.fire({

                        icon: "success",

                        title: isUpdate
                            ? "Auction Updated"
                            : "Auction Created",

                        text: result.message,

                        confirmButtonText: "OK"

                    }).then(() => {

                        window.location.href =
                            "/Business/Home/Auctions";

                    });

                }
                else {

                    Swal.fire(

                        "Error",

                        result.message ||

                        "Unable to save auction.",

                        "error"

                    );

                }

            }

            catch (ex) {

                hideLoading();

                console.log(ex);

                Swal.fire(

                    "Error",

                    ex.message,

                    "error"

                );

            }

        }

        //////////////////////////////////////////////////////
        // Reset Form
        //////////////////////////////////////////////////////

        $("#auctionForm").on("reset", function () {

            setTimeout(function () {

                $("#previewContainer").empty();

                $("#oldImagesContainer").empty();

                $("#Duration").val("");

              
                selectedFiles = [];

                existingImages = [];

                removedImages = [];


                toggleRegistrationFields();

            }, 200);

        });

        //////////////////////////////////////////////////////
        // Prevent Multiple Submit
        //////////////////////////////////////////////////////

        $("#btnSave,#btnUpdate").on("dblclick", function (e) {

            e.preventDefault();

        });

        //////////////////////////////////////////////////////
        // Close Script
        //////////////////////////////////////////////////////

    </script>

</body>

</html>

