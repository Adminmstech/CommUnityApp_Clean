@using System.Security.Claims
@{
    ViewData["Title"] = "Bid Item Enrolment";
    Layout = null;

    // 🔹 Get UserId from Cookie Claim
    var userId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>@ViewData["Title"]</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <style>
       

        @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
       
        :root {
            --background: #0f0f0f;
            --foreground: #e4e4e7;
            --card: #1a1a1a;
            --section: #222222;
            --accent: #f6af3e;
            --muted: #27272a;
            --muted-foreground: #a1a1aa;
            --border: #2e2e2e;
            --danger: #ef4444;
            --radius-lg: 14px;
            --radius-md: 10px;
            --shadow: 0 25px 60px rgba(0,0,0,0.65);
        }


       

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter',sans-serif;
            background: linear-gradient( 180deg, #0c0c0c 0%, #121212 100% );
            color: var(--foreground);
            padding: 60px 20px;
        }


   

        h1, h2, h3, h4, h5, h6 {
            font-family: 'Plus Jakarta Sans',sans-serif;
        }

        h1 {
            font-size: 38px;
            font-weight: 800;
            color: var(--accent);
            margin-bottom: 10px;
        }

        .subtitle {
            color: var(--muted-foreground);
            margin-bottom: 40px;
        }

        label {
            color: #d4d4d8;
            font-size: 14px;
        }



        .form-wrapper {
            max-width: 1000px;
            margin: auto;
            background: var(--card);
            border-radius: var(--radius-lg);
            padding: 50px;
            border: 1px solid var(--border);
            box-shadow: var(--shadow);
        }


        

        section {
            background: var(--section);
            border-radius: var(--radius-md);
            padding: 30px;
            margin-bottom: 30px;
            border: 1px solid var(--border);
        }

            section h2 {
                color: var(--accent);
                font-size: 18px;
                margin-bottom: 20px;
            }



        .grid-2 {
            display: grid;
            grid-template-columns: repeat(auto-fit,minmax(220px,1fr));
            gap: 20px;
        }

        .field {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin-bottom: 18px;
        }


     

        input,
        select,
        textarea {
            padding: 14px 16px;
            border-radius: 10px;
            border: 1px solid #2f2f2f;
            background: #151515;
            color: #ffffff;
            font-size: 14px;
            transition: all .2s ease;
        }

            input::placeholder,
            textarea::placeholder {
                color: #777;
            }

            input:focus,
            select:focus,
            textarea:focus {
                outline: none;
                border-color: var(--accent);
                box-shadow: 0 0 0 2px rgba(245,158,11,.25);
                background: #181818;
            }

        .radio-group {
            display: flex;
            gap: 14px;
        }

        .primary {
            padding: 14px 34px;
            border-radius: 999px;
            font-weight: 700;
            border: none;
            cursor: pointer;
            background: linear-gradient( 135deg, #f59e0b, #fbbf24 );
            color: #111;
            transition: .25s;
        }

            .primary:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 25px rgba(0,0,0,.45);
            }



        .actions {
            display: flex;
            justify-content: center;
            margin-top: 40px;
        }



        .duration-display {
            color: #22c55e;
            font-weight: 600;
            margin-top: 8px;
        }

        span {
            color: var(--danger);
            font-weight: 600;
            margin-left: 4px;
        }


        @@keyframes fade-up {

            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .fade-up {
            animation: fade-up .8s ease-out;
        }


        @@keyframes coin-spin {

            from {
                transform: rotateY(0deg);
            }

            to {
                transform: rotateY(360deg);
            }
        }

        .coin-spin {
            animation: coin-spin 3s linear infinite;
        }


        @@keyframes float-particle {

            0% {
                transform: translateY(0px);
                opacity: .8;
            }

            50% {
                transform: translateY(-20px);
                opacity: 1;
            }

            100% {
                transform: translateY(0px);
                opacity: .8;
            }
        }

        .float-particle {
            animation: float-particle 6s infinite ease-in-out;
        }
        .section-header {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 20px;
        }

        .section-icon {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
            background: rgba(246,175,62,0.15);
            color: #ffffff;
            font-size: 18px;
            border: 1px solid rgba(246,175,62,0.25);
        }

        .section-label {
            font-size: 11px;
            letter-spacing: 2px;
            color: var(--muted-foreground);
            display: block;
            margin-bottom: 2px;
        }

        .section-header h2 {
            font-size: 18px;
            font-weight: 800;
            color: #f6af3e;
            margin: 0;
        }
    </style>
</head>

<body>
    @* <header class="main-header">

        <div class="header-left">
            <h3 class="logo">Auction Panel</h3>
