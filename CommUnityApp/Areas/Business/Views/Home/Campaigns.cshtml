@{
    ViewData["Title"] = "Campaign List";
    Layout = "_BusinessLayout";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Campaign List</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #EDF2FF;
            font-family: "Segoe UI", sans-serif;
        }

        .card {
            border: none;
            border-radius: 12px;
            overflow: hidden;
            background: #f4f7fe;
            transition: 0.3s;
        }

            .card:hover {
                transform: translateY(-5px);
            }

            .card img {
                height: 180px;
                object-fit: cover;
            }

        .badge {
            font-size: 12px;
        }

        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .btn-add {
            background: #f6af3e;
            border: none;
            font-weight: 600;
        }

            .btn-add:hover {
                background: #e69c2f;
            }

        .card-body h5 {
            font-weight: 600;
        }
    </style>
</head>

<body>

    <div class="container mt-5">

        <div class="top-bar mb-4">
            <h4>My Campaigns</h4>
            <a href="/Business/Home/AddCampaign" class="btn btn-add text-white">
                + Add Campaign
            </a>
        </div>

        <div id="campaignList" class="row"></div>

    </div>

    <script>

        document.addEventListener("DOMContentLoaded", loadCampaigns);

        function loadCampaigns(){

            fetch("/api/Campaign/Business_campaigns")
            .then(res => res.json())
            .then(data => {

                const container = document.getElementById("campaignList");
                container.innerHTML = "";

                if(!data || data.length === 0){
                    container.innerHTML = "<div class='text-center'>No campaigns found</div>";
                    return;
                }

                data.forEach(c => {

                    const imagePath = c.campaignImage ? "/" + c.campaignImage : "https://via.placeholder.com/400x200";

                    const card = `
                        <div class="col-md-4 mb-4">
                            <div class="card shadow-sm">

                                <img src="${imagePath}" />

                                <div class="card-body">

                                    <h5>${c.campaignName}</h5>
                                    <p class="text-muted">${c.shortNote ?? ""}</p>

                                    <div class="mb-2">
                                        <span class="badge bg-primary">${c.campaignType ?? "General"}</span>
                                        <span class="badge bg-success">${c.campaignStage}</span>
                                    </div>

                                    <p>
                                        📍 ${c.targetLocation ?? "N/A"} <br/>
                                        💰 Budget: ₹${c.budget ?? 0}
                                    </p>

                                    <p>
                                        📅 ${formatDate(c.startDate)} - ${formatDate(c.endDate)}
                                    </p>

                                    <div class="d-flex justify-content-between">

                                        <a href="${c.promotionLink}" target="_blank"
                                           class="btn btn-sm btn-outline-primary">
                                           View
                                        </a>

                                               <a href="/Business/Home/AddCampaign?campaignId=${c.campaignId}"
                                                class="btn btn-sm btn-warning">
                                               <i class="fa-solid fa-pen"></i> Edit
                                          </a>

                                    </div>

                                </div>
                            </div>
                        </div>
                    `;

                    container.innerHTML += card;

                });

            })
            .catch(() => {
                document.getElementById("campaignList").innerHTML =
                    "<div class='text-danger'>Error loading campaigns</div>";
            });
        }

        function formatDate(dateStr){
            if(!dateStr) return "";
            const d = new Date(dateStr);
            return d.toLocaleDateString();
        }

    </script>

</body>
</html>