@{
    ViewData["Title"] = "Promotion Details";
    Layout = "_BusinessLayout";
}

<div class="container-fluid">

    <div id="promotionDetails">

        Loading...

    </div>

</div>

@section Scripts {

    <script>

        const params =
            new URLSearchParams(window.location.search);

        const promotionId =
            params.get("promotionId");

        $(document).ready(function(){

            loadDetails();

        });

        function loadDetails(){

            $.ajax({

                url:'/api/Product/Get_PromotionDetails?promotionId='
                    + promotionId,

                type:'GET',

                success:function(data){

                    renderDetails(data);
                }
            });
        }

        function renderDetails(item) {

            let html = `

            <div class="card shadow border-0">

                <div class="card-header bg-primary text-white">

                    <h3 class="mb-0">
                        ${item.promotionTitle}
                    </h3>

                </div>

                <div class="card-body">

                    <div class="row">

                        <div class="col-md-4 text-center">

                            <img src="/${item.promotionImage}"
                                 class="img-fluid rounded shadow-sm mb-3"
                                 style="max-height:300px;" />

                            <div class="border rounded p-3 bg-light">

                                <h6 class="mb-2">Promotion QR Code</h6>

                                <img src="${item.qrCodeImage}"
                                     class="img-fluid"
                                     style="max-width:220px;" />
                            </div>

                        </div>

                        <div class="col-md-8">

                            <table class="table table-bordered">

                                <tr>
                                    <th width="35%">Business</th>
                                    <td>${item.businessName || '-'}</td>
                                </tr>

                                <tr>
                                    <th>Featured Products / Services</th>
                                    <td>${item.featuredProducts || '-'}</td>
                                </tr>

                                <tr>
                                    <th>Offer Headline</th>
                                    <td>${item.offerHeadline || '-'}</td>
                                </tr>

                                <tr>
                                    <th>Promotional Price</th>
                                    <td>$${item.promotionalPrice || 0}</td>
                                </tr>

                                <tr>
                                    <th>Max Coins Redemption</th>
                                    <td>${item.maxCoinsRedemptionPercentage || 0}%</td>
                                </tr>

                                <tr>
                                    <th>IndoCoins Earned</th>
                                    <td>${item.indoCoinsEarned || 0}</td>
                                </tr>

                                <tr>
                                    <th>Friend Reward Coins</th>
                                    <td>${item.friendRewardCoins || 0}</td>
                                </tr>

                                <tr>
                                    <th>Promotion URL</th>
                                    <td>
                                        <a href="${item.promotionUrl}"
                                           target="_blank">
                                            Open Promotion
                                        </a>
                                    </td>
                                </tr>

                                <tr>
                                    <th>Start Date</th>
                                    <td>${formatDate(item.startDate)}</td>
                                </tr>

                                <tr>
                                    <th>End Date</th>
                                    <td>${formatDate(item.endDate)}</td>
                                </tr>

                                <tr>
                                    <th>Status</th>
                                    <td>
                                        ${item.isActive
                    ? '<span class="badge bg-success">Active</span>'
                    : '<span class="badge bg-danger">Inactive</span>'}
                                    </td>
                                </tr>

                                <tr>
                                    <th>Business Address</th>
                                    <td>${item.address || '-'}</td>
                                </tr>

                                <tr>
                                    <th>Phone</th>
                                    <td>${item.phone || '-'}</td>
                                </tr>

                            </table>

                            <div class="mt-3">

                                <button
                                    onclick="sharePromotion('${item.promotionUrl}')"
                                    class="btn btn-success">

                                    <i class="fa fa-share-alt me-2"></i>
                                    Share Promotion

                                </button>

                                @*<a href="${item.qrCodeImage}"
                                   download
                                   class="btn btn-info">

                                    <i class="fa fa-download me-2"></i>
                                    Download QR

                                </a>*@

                            </div>

                        </div>

                    </div>

                </div>

            </div>
            `;

            $("#promotionDetails").html(html);
        }

        function sharePromotion(url){

            window.open(
                "https://wa.me/?text=" +
                encodeURIComponent(url),
                "_blank"
            );
        }
        function formatDate(dateString) {

            if (!dateString)
                return "-";

            return new Date(dateString)
                .toLocaleString();
        }
    </script>

}