@{
    ViewData["Title"] = "Add Service";
    var businessId = Context.Session.GetString("BusinessId");
    Layout = "_BusinessLayout";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Service</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: #EDF2FF;
            font-family: "Segoe UI", sans-serif;
        }

        .card {
            border-radius: 12px;
            background: #f4f7fe;
        }

        .card-header {
            background: #212529;
            color: #fff;
            font-weight: 600;
        }

        .form-label {
            font-weight: 600;
        }

        .preview-img {
            width: 90px;
            height: 90px;
            object-fit: cover;
            border-radius: 8px;
            margin: 5px;
            border: 1px solid #ddd;
        }

        .btn-submit {
            background: #f6af3e;
            border: none;
            padding: 12px;
            font-weight: 600;
        }
    </style>
</head>

<body>

    <div class="container mt-5">
        <div class="card shadow">
            <div class="card-header">
                Add Service
            </div>

            <div class="card-body">

                <div id="result"></div>

                <form id="serviceForm">

                    <!-- BusinessId from session -->
                    <input type="hidden" id="businessId" value="@businessId" />

                    <!-- Service Name -->
                    <div class="mb-3">
                        <label class="form-label">Service Name</label>
                        <input type="text" id="serviceName" class="form-control" required>
                    </div>

                    <!-- Description -->
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea id="description" class="form-control"></textarea>
                    </div>

                    <!-- Images -->
                    <div class="mb-3">
                        <label class="form-label">Upload Images</label>
                        <input type="file" id="serviceImages" class="form-control" multiple accept="image/*">
                        <div id="imagePreview" class="d-flex flex-wrap mt-2"></div>
                    </div>

                    <button type="submit" class="btn btn-submit w-100">
                        Add Service
                    </button>

                </form>

            </div>
        </div>
    </div>

    <script>

        let imageList = [];

        /* Convert to Base64 */
        function convertToBase64(file){
            return new Promise((resolve,reject)=>{
                const reader = new FileReader();
                reader.onload = ()=> resolve(reader.result);
                reader.onerror = err => reject(err);
                reader.readAsDataURL(file);
            });
        }

        /* Image Upload */
        document.getElementById("serviceImages").addEventListener("change", async function(){

            imageList = [];
            document.getElementById("imagePreview").innerHTML = "";

            const files = this.files;

            for(let i=0;i<files.length;i++)
            {
                const base64 = await convertToBase64(files[i]);

                imageList.push({
                    imageBase64: base64,
                    isPrimary: (i === 0)
                });

                const img = document.createElement("img");
                img.src = base64;
                img.className = "preview-img";

                document.getElementById("imagePreview").appendChild(img);
            }

        });

        /* Submit */
        document.getElementById("serviceForm").addEventListener("submit", function(e){

            e.preventDefault();

            const businessId = document.getElementById("businessId").value;

            if(!businessId || businessId === "null"){
                alert("Session expired. Please login again.");
                return;
            }

            const data = {
                service: {
                    businessId: parseInt(businessId),
                    serviceName: document.getElementById("serviceName").value,
                    description: document.getElementById("description").value
                },
                images: imageList
            };

            fetch("/api/Service/UploadService", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json"
                },
                body: JSON.stringify(data)
            })
            .then(res => res.json())
            .then(result => {

                if(result.success){
                    document.getElementById("result").innerHTML =
                        "<div class='alert alert-success'>Service added successfully</div>";

                    document.getElementById("serviceForm").reset();
                    document.getElementById("imagePreview").innerHTML = "";
                    imageList = [];
                }
                else{
                    document.getElementById("result").innerHTML =
                        "<div class='alert alert-danger'>" + (result.message || "Failed to add service") + "</div>";
                }

            })
            .catch(() => {
                document.getElementById("result").innerHTML =
                    "<div class='alert alert-danger'>Server error</div>";
            });

        });

    </script>

</body>
</html>