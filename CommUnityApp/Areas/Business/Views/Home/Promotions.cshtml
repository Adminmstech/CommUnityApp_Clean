@{
    ViewData["Title"] = "Products";
    var businessId = ViewBag.BusinessId;
    Layout = "_BusinessLayout";
}

<!DOCTYPE html>
<html>
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Products</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>

        .product-img {
            width: 60px;
            height: 60px;
            object-fit: cover;
            border-radius: 6px;
        }

    </style>

</head>

<body>

    <div class="container mt-4">

        <div class="d-flex justify-content-between align-items-center mb-3">

            <h3 class="fw-bold">Products</h3>

            <a href="/Business/Home/AddProduct" class="btn btn-primary">
                + Add Product
            </a>

        </div>

        <div class="card shadow-sm">

            <div class="card-body p-0">

                <table class="table table-bordered table-hover mb-0">

                    <thead class="table-dark">

                        <tr>
                            <th style="width:90px">Image</th>
                            <th>Product Name</th>
                            <th>Category</th>
                            <th>Price</th>
                            <th>Discount Price</th>
                            <th>Coins (%)</th>
                            <th>Refer Friend</th>
                            <th style="width:120px">Action</th>
                        </tr>

                    </thead>

                    <tbody id="productTable">

                        <tr>
                            <td colspan="8" class="text-center p-3">
                                Loading products...
                            </td>
                        </tr>

                    </tbody>

                </table>

            </div>

        </div>

    </div>


    <script>

        const businessId = '@businessId';

        async function loadProducts(){

            try{

                const response = await fetch(`/api/Product/Get_ProductByBusinessId?BusinessId=${businessId}`);

                const data = await response.json();

                let rows = "";

                if(data.length === 0){

                    rows = `
                        <tr>
                            <td colspan="8" class="text-center p-4">
                                No products found
                            </td>
                        </tr>
                    `;
                }

                data.forEach(item => {

                    let image = "/images/no-image.png";

                    if(item.images && item.images.length > 0){
                        image = "/" + item.images[0].imagePath;
                    }

                    rows += `
                        <tr>

                            <td>
                                <img src="${image}" class="product-img"/>
                            </td>

                            <td>${item.product.productName ?? ""}</td>

                            <td>${item.product.productCategory ?? ""}</td>

                            <td>${item.product.price ?? ""}</td>

                            <td>${item.product.discountPrice ?? ""}</td>

                            <td>${item.product.redemptionCoins ?? 0}%</td>

                            <td>
                                ${item.product.referAFriend
                                    ? "<span class='badge bg-success'>Yes</span>"
                                    : "<span class='badge bg-secondary'>No</span>"
                                }
                            </td>

                            <td>

                                <button class="btn btn-warning btn-sm"
                                    onclick="editProduct(${item.product.productId})">

                                    Edit

                                </button>

                            </td>

                        </tr>
                    `;
                });

                document.getElementById("productTable").innerHTML = rows;

            }
            catch(error){

                console.error("Error loading products:", error);

                document.getElementById("productTable").innerHTML =
                `
                <tr>
                    <td colspan="8" class="text-center text-danger p-4">
                        Failed to load products
                    </td>
                </tr>
                `;
            }

        }


        function editProduct(id){

            window.location.href = "/Business/Home/AddProduct?productId=" + id;

        }


        loadProducts();

    </script>


</body>
</html>