@{
    ViewData["Title"] = "Profile";
    var businessId = ViewBag.BusinessId;
    Layout = "_BusinessLayout";
}



<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Business Profile</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>

        body {
            background: #f3f5f9;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* Top Banner */

        .profile-banner {
            background: linear-gradient(135deg,#1d3557,#457b9d);
            height: 160px;
            border-radius: 12px;
        }

        /* Profile container */

        .profile-wrapper {
            max-width: 950px;
            margin: 40px auto;
        }

        /* Profile main card */

        .profile-main {
            background: white;
            border-radius: 12px;
            margin-top: -70px;
            padding: 30px;
            text-align: center;
            box-shadow: 0 6px 18px rgba(0,0,0,0.08);
        }

        /* Logo */

        .business-logo {
            width: 190px;
            height: 130px;
            border-radius: 12px;
            object-fit: cover;
            border: 3px solid #17a2a0;
            margin-top: -80px;
        }

        /* Business name */

        #businessName {
            font-size: 26px;
            font-weight: 600;
            margin-top: 10px;
        }

        /* Category */

        #category {
            color: #6c757d;
            font-size: 14px;
        }

        /* Info cards */

        .info-section {
            margin-top: 25px;
        }

        .info-card {
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.06);
        }

        /* Titles */

        .section-title {
            font-weight: 600;
            font-size: 16px;
            margin-bottom: 15px;
            border-bottom: 1px solid #eee;
            padding-bottom: 6px;
        }

        /* Labels */

        .info-label {
            font-weight: 600;
            color: #444;
        }

        /* Row spacing */

        .info-row {
            margin-bottom: 10px;
        }

    </style>
</head>

<body>

    <div class="profile-wrapper">

        <!-- Banner -->
        <div class="profile-banner"></div>

        <!-- Profile Card -->
        <div class="profile-main">

            <img id="logo" class="business-logo" src="">

            <h3 id="businessName"></h3>
            <p id="category"></p>

        </div>

        <!-- Contact Section -->
        <div class="row info-section">

            <div class="col-md-6">
                <div class="info-card">

                    <div class="section-title">Contact Info</div>

                    <div class="info-row">
                        <span class="info-label">Owner:</span>
                        <span id="ownerName"></span>
                    </div>

                    <div class="info-row">
                        <span class="info-label">Phone:</span>
                        <span id="phone"></span>
                    </div>

                    <div class="info-row">
                        <span class="info-label">Email:</span>
                        <span id="email"></span>
                    </div>

                </div>
            </div>

            <div class="col-md-6">
                <div class="info-card">

                    <div class="section-title">Location</div>

                    <div class="info-row">
                        <span class="info-label">City:</span>
                        <span id="city"></span>
                    </div>

                    <div class="info-row">
                        <span class="info-label">State:</span>
                        <span id="state"></span>
                    </div>

                    <div class="info-row">
                        <span class="info-label">Country:</span>
                        <span id="country"></span>
                    </div>

                </div>
            </div>

        </div>

        <!-- Address -->
        <div class="info-section">
            <div class="info-card">

                <div class="section-title">Address</div>

                <p id="address"></p>

            </div>
        </div>

        <!-- Description -->
        <div class="info-section">
            <div class="info-card">

                <div class="section-title">Business Description</div>

                <p id="info"></p>

            </div>
        </div>

    </div>


    <script>

        const businessId = 5; // change dynamically if needed

        fetch(`/api/Business/Get_BusinessDetails?BusinessId=${businessId}`)
        .then(res => res.json())
        .then(data => {

            document.getElementById("businessName").innerText = data.businessName;
            document.getElementById("category").innerText = data.categoryName;

            document.getElementById("ownerName").innerText = data.ownerName;
            document.getElementById("phone").innerText = data.phone;
            document.getElementById("email").innerText = data.businessEmail;

            document.getElementById("city").innerText = data.city;
            document.getElementById("state").innerText = data.state;
            document.getElementById("country").innerText = data.country;

            document.getElementById("address").innerText = data.address;
            document.getElementById("info").innerText = data.info;

            document.getElementById("logo").src = "/" + data.logo;

        });

    </script>

</body>
</html>