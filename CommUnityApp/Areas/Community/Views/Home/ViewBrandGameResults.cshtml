@{
    ViewData["Title"] = "Brand Game Results";
    Layout = "~/Areas/Community/Views/Shared/_CommunityLayout.cshtml";
}

<div class="container mt-3">

    <h4>Game Play Members</h4>

    <div class="row mb-2">
        <div class="col-md-4">
            <input type="text" id="txtSearch" class="form-control" placeholder="Search name / mobile / game..." />
        </div>
        <div class="col-md-2">
            <button class="btn btn-primary w-100" onclick="loadData()">Search</button>
        </div>
    </div>

    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Name</th>
                <th>Mobile</th>
                <th>Game</th>
                <th>Attempts</th>
                <th>Prize</th>
                <th>Prize Image</th>
                <th>Winner</th>
                <th>Status</th>
                <th>Date</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody id="tblData"></tbody>
    </table>

    <div class="d-flex justify-content-between">
        <div id="rowInfo"></div>
        <div>
            <button class="btn btn-sm btn-primary" onclick="prev()">Prev</button>
            <span id="pageNo">1</span>
            <button class="btn btn-sm btn-primary" onclick="next()">Next</button>
        </div>
    </div>

</div>

<!-- Assign Prize Modal -->
<div class="modal fade" id="assignModal">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5>Assign Prize</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <!-- ✅ CHANGED TO USERID -->
                <input type="hidden" id="hdnUserId" />

                <div class="mb-2">
                    <label>Name</label>
                    <input type="text" id="txtName" class="form-control" readonly />
                </div>

                <div class="mb-2">
                    <label>Mobile</label>
                    <input type="text" id="txtMobile" class="form-control" readonly />
                </div>

                <div class="mb-2">
                    <label>Prize</label>
                    <input type="text" id="txtPrize" class="form-control" readonly />
                </div>

                <div class="mb-2">
                    <label>Delivery Address</label>
                    <textarea id="txtAddress" class="form-control"></textarea>
                </div>

                <div class="mb-2">
                    <label>Assign Volunteer</label>
                    <select id="ddlVolunteer" class="form-control">
                        <option value="">-- Select Volunteer --</option>
                    </select>
                </div>

                <div class="mb-2">
                    <label>Delivery Type</label>
                    <select id="ddlType" class="form-control">
                        <option value="Courier">Courier</option>
                        <option value="Pickup">Pickup</option>
                    </select>
                </div>

            </div>

            <div class="modal-footer">
                <button class="btn btn-primary" onclick="savePrize()">Submit</button>
            </div>

        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>

    var page = 1;
    var size = 5;
    var total = 0;

    $(document).ready(function () {
        loadData();
    });

    function loadData() {

        var search = $("#txtSearch").val();

        $.get('/api/GameResults/GetBrandGamePlayMembers?page=' + page + '&size=' + size + '&search=' + search, function (res) {

            var html = "";
            var data = res.data || res.Data;
            total = res.totalCount || res.TotalCount;

            if (!data || data.length === 0) {
                html = "<tr><td colspan='11' class='text-center'>No data</td></tr>";
            } else {

                $.each(data, function (i, x) {

                    var isWinner = x.isWinner || x.IsWinner;
                    var prizeImage = x.prizeImage || x.PrizeImage;
                    var status = x.status || x.Status || "Pending";

                    html += "<tr>";

                    html += "<td>" + ((page - 1) * size + i + 1) + "</td>";
                    html += "<td>" + (x.fullName || x.FullName || '-') + "</td>";
                    html += "<td>" + (x.mobile || x.Mobile || '-') + "</td>";
                    html += "<td>" + (x.brandGameTitle || x.BrandGameTitle || '-') + "</td>";
                    html += "<td>" + (x.attemptNumber || x.AttemptNumber || 0) + "</td>";
                    html += "<td>" + (x.prizeType || x.PrizeType || '-') + "</td>";

                    html += "<td>" +
                        (prizeImage
                            ? `<img src="/${prizeImage.replace('~/', '')}"
                                    style="width:60px;height:60px;border-radius:6px;cursor:pointer"
                                    onclick="window.open('/${prizeImage}','_blank')" />`
                            : "-")
                        + "</td>";

                    html += "<td>" + (isWinner ? "Yes" : "No") + "</td>";

                    var statusBadge = "";

                    if (status === "Pending") {
                        statusBadge = `<span class="badge bg-warning text-dark">Pending</span>`;
                    }
                    else if (status === "Won") {
                        statusBadge = `<span class="badge bg-success">Won</span>`;
                    }
                    else if (status === "Assigned") {
                        statusBadge = `<span class="badge bg-info text-dark">Assigned</span>`;
                    }
                    else if (status === "Delivered") {
                        statusBadge = `<span class="badge bg-primary">Delivered</span>`;
                    }
                    else {
                        statusBadge = `<span class="badge bg-secondary">${status}</span>`;
                    }

                    html += "<td>" + statusBadge + "</td>";

                    html += "<td>" +
                        ((x.playedAt || x.PlayedAt)
                            ? new Date(x.playedAt || x.PlayedAt).toLocaleString()
                            : "-") +
                        "</td>";

                    if (isWinner) {
                        html += `<td>
                                <button class="btn btn-success btn-sm"
                                    onclick="assignPrize('${x.userId || x.UserId}',
                                                          '${x.fullName || x.FullName}',
                                                          '${x.mobile || x.Mobile}',
                                                          '${x.prizeType || x.PrizeType}')">
                                    Assign
                                </button>
                            </td>`;
                    } else {
                        html += "<td>-</td>";
                    }

                    html += "</tr>";
                });
            }

            $("#tblData").html(html);
            $("#pageNo").text(page);
            $("#rowInfo").text("Showing " + ((page - 1) * size + 1) + " to " + Math.min(page * size, total) + " of " + total);
        });
    }

    function assignPrize(userId, name, mobile, prize) {

        $("#hdnUserId").val(userId);
        $("#txtName").val(name);
        $("#txtMobile").val(mobile);
        $("#txtPrize").val(prize);
        $("#txtAddress").val("");

        loadVolunteers();

        $("#assignModal").modal('show');
    }

    function savePrize() {

        var obj = {
            UserId: $("#hdnUserId").val(), 
            Address: $("#txtAddress").val(),
            DeliveryType: $("#ddlType").val(),
            VolunteerId: $("#ddlVolunteer").val()
        };

        if (!obj.VolunteerId) {
            alert("Please select volunteer");
            return;
        }

        $.ajax({
            url: '/api/GameResults/AssignPrize',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(obj),
            success: function (res) {
                if (res.status) {
                    alert("Prize assigned successfully!");
                    $("#assignModal").modal('hide');
                    loadData();
                } else {
                    alert("Failed");
                }
            }
        });
    }

    function loadVolunteers() {

        $.ajax({
            url: '/api/Community/GetVolunteers',
            type: 'GET',
            success: function (res) {

                var data = res.data || res.Data || res;

                var html = "<option value=''>-- Select Volunteer --</option>";

                $.each(data, function (i, x) {
                    html += `<option value="${x.UserId}">
                                    ${x.FullName} (${x.Mobile})
                                 </option>`;
                });

                $("#ddlVolunteer").html(html);
            }
        });
    }

    function next() {
        if ((page * size) < total) {
            page++;
            loadData();
        }
    }

    function prev() {
        if (page > 1) {
            page--;
            loadData();
        }
    }

</script>