@{
    ViewData["Title"] = "Community Posts";
    Layout = "~/Areas/Community/Views/Shared/_CommunityLayout.cshtml";
}

<div class="container mt-4">

    <div class="d-flex
                justify-content-between
                align-items-center
                mb-4">

        <h3>

            <i class="fa-solid fa-comments"></i>
            Community Posts

        </h3>

    </div>

    <div class="row"
         id="postsContainer">
    </div>

</div>

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>

    $(document).ready(function () {

        loadPosts();
    });

   

    function loadPosts() {

        let communityId =
            "@Context.Session.GetString("CommunityId")";

        $.get(
            `/api/Community/GetCommunityPosts/${communityId}`,

            function (res) {

                let html = "";

                if (res.data.length == 0) {

                    html = `
                        <div class="col-12">

                            <div class="alert alert-warning">

                                No posts available

                            </div>

                        </div>`;
                }

                res.data.forEach(p => {

                    html += `

                        <div class="col-lg-4 col-md-6 mb-4">

                            <div class="card
                                        border-0
                                        shadow-sm
                                        h-100">

                                ${p.imagePath
                            ?
                            `<img src="${p.imagePath}"
                                          class="card-img-top"
                                          style="
                                            height:240px;
                                            object-fit:cover;">`
                            : ''
                        }

                                <div class="card-body">

                                    <h5 class="fw-bold">

                                        ${p.title}

                                    </h5>

                                    <p>

                                        ${p.message}

                                    </p>

                                </div>

                                <div class="card-footer
                                            bg-white
                                            border-0">

                                    <small class="text-muted">

                                        <i class="fa-regular fa-clock"></i>

                                        ${p.createdDateString}

                                    </small>

                                </div>

                            </div>

                        </div>`;
                });

                $("#postsContainer").html(html);
            });
    }

</script>