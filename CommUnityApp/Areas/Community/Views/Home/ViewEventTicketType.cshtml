@{
    ViewData["Title"] = "Event Ticket Types";
    Layout = "~/Areas/Community/Views/Shared/_CommunityLayout.cshtml";
}
<link rel="stylesheet"
      href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" />

<link rel="stylesheet"
      href="https://cdn.datatables.net/1.13.8/css/jquery.dataTables.min.css" />

<link rel="stylesheet"
      href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.dataTables.min.css" />
<div class="card shadow">

    <div class="card-header text-white"
         style="background-color:black;">

        <div class="d-flex justify-content-between align-items-center">

            <h4 class="mb-0">
                Event Ticket Types
            </h4>

            <a href="/Community/Home/AddEventTicketType"
               class="btn btn-light">
                <i class="fa fa-plus"></i> Add Ticket Type
            </a>

        </div>

    </div>

    <div class="card-body">

        <table class="table table-bordered table-striped"
               id="tblTicketTypes"
               style="width:100%">

            <thead>
                <tr>
                    <th>S.No</th>
                    <th>Event</th>
                    <th>Ticket Type</th>
                    <th>Price</th>
                    <th>Total</th>
                    <th>Sold</th>
                    <th>Remaining</th>
                    <th>Max/User</th>
                    <th>Transferable</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody></tbody>

        </table>
    </div>

</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>

<script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
<script>

    $(document).ready(function () {

        LoadTicketTypes();

    });

    function LoadTicketTypes() {

        $.ajax({

            url: '/api/Event/GetEventTicketTypes',
            type: 'GET',

            success: function (response) {

                var rows = '';

                $.each(response, function (i, item) {

                    rows += '<tr>';

                    rows += '<td>' + (i + 1) + '</td>';
                    rows += '<td>' + item.eventName + '</td>';
                    rows += '<td>' + item.ticketTypeName + '</td>';
                    rows += '<td>$' + item.price + '</td>';
                    rows += '<td>' + item.totalTickets + '</td>';
                    rows += '<td>' + item.soldTickets + '</td>';
                    rows += '<td>' + item.remainingTickets + '</td>';
                    rows += '<td>' + item.maxPerUser + '</td>';
                    rows += '<td>' + (item.isTransferable ? 'Yes' : 'No') + '</td>';

                    rows += '<td>';

                    rows += '<button class="btn btn-danger btn-sm" ';
                    rows += 'onclick="DeleteTicketType(' + item.ticketTypeId + ')">';
                    rows += 'Delete';
                    rows += '</button>';

                    rows += '</td>';

                    rows += '</tr>';
                });

                $("#tblTicketTypes tbody").html(rows);

                if ($.fn.DataTable.isDataTable('#tblTicketTypes')) {
                    $('#tblTicketTypes').DataTable().destroy();
                }

                $('#tblTicketTypes').DataTable({
                    responsive: true,
                    paging: true,
                    searching: true,
                    info: true,
                    ordering: true,
                    pageLength: 10,
                    lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]]
                });
            }
        });
    }

    function DeleteTicketType(ticketTypeId) {

        if (!confirm("Are you sure you want to delete this ticket type?"))
            return;

        $.ajax({

            url: '/api/Event/DeleteEventTicketType?ticketTypeId=' + ticketTypeId,
            type: 'DELETE',

            success: function (response) {

                alert("Deleted Successfully");

                LoadTicketTypes();

            }
        });
    }

</script>