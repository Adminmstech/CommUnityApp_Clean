@{
    ViewData["Title"] = "Add Community Post";
    Layout = "~/Areas/Community/Views/Shared/_CommunityLayout.cshtml";
}

<div class="container-fluid mt-4">

    <!-- CREATE POST -->

    <div class="card shadow-sm border-0 mb-4">

        <div class="card-body">

            <h4 class="mb-4">

                <i class="fa-solid fa-pen-to-square"></i>

                Create Community Post

            </h4>

            <div class="row">

                <!-- TITLE -->

                <div class="col-md-4 mb-3">

                    <label class="form-label">
                        Title
                    </label>

                    <input type="text"
                           id="title"
                           class="form-control"
                           placeholder="Enter title" />

                </div>

                <!-- IMAGE -->

                <div class="col-md-4 mb-3">

                    <label class="form-label">
                        Upload Image
                    </label>

                    <input type="file"
                           id="imageFile"
                           class="form-control" />

                </div>

                <!-- BUTTON -->

                <div class="col-md-4 d-flex align-items-end">

                    <button class="btn btn-primary w-100"
                            onclick="savePost()">

                        <i class="fa-solid fa-paper-plane"></i>

                        Post Message

                    </button>

                </div>

            </div>

            <!-- MESSAGE -->

            <div class="mb-3">

                <label class="form-label">
                    Message
                </label>

                <textarea id="message"
                          class="form-control"
                          rows="4"
                          placeholder="Write message"></textarea>

            </div>

            <!-- PREVIEW -->

            <div class="text-center">

                <img id="previewImage"
                     style="
                        width:300px;
                        max-height:220px;
                        object-fit:cover;
                        border-radius:12px;
                        display:none;" />

            </div>

        </div>

    </div>

    <!-- POSTS GRID -->

    <div class="card shadow-sm border-0">

        <div class="card-body">

            <h4 class="mb-4">

                <i class="fa-solid fa-list"></i>

                Community Posts

            </h4>

            <div class="table-responsive">

                <table class="table table-bordered
                              align-middle">

                    <thead class="table-dark">

                        <tr>

                            <th>#</th>

                            <th>Image</th>

                            <th>Title</th>

                            <th>Message</th>

                            <th>Posted Date</th>

                            <th>Actions</th>

                        </tr>

                    </thead>

                    <tbody id="postsContainer">
                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>


    $("#imageFile").change(function () {

        let file = this.files[0];

        if (file) {

            let reader = new FileReader();

            reader.onload = function (e) {

                $("#previewImage")
                    .attr("src", e.target.result)
                    .show();
            };

            reader.readAsDataURL(file);
        }
    });



    $(document).ready(function () {

        loadPosts();
    });

    

    function savePost() {

        let title =
            $("#title").val().trim();

        let message =
            $("#message").val().trim();


        if (title == "") {

            alert("Please enter title");

            return;
        }

        if (message == "") {

            alert("Please enter message");

            return;
        }

      

        let formData = new FormData();

        formData.append(
            "CommunityId",
            "@Context.Session.GetString("CommunityId")");

        formData.append(
            "Title",
            title);

        formData.append(
            "Message",
            message);

        formData.append(
            "CreatedBy",
            "@Context.Session.GetString("CommunityId")");

      

        let file =
            $("#imageFile")[0].files[0];

        if (file != null) {

            formData.append(
                "ImageFile",
                file);
        }


        $.ajax({

            url:
                "/api/Community/AddCommunityPost",

            type: "POST",

            data: formData,

            processData: false,

            contentType: false,

            success: function (res) {


                alert(
                    res.resultMessage ||
                    res.ResultMessage ||
                    "Post added successfully"
                );

               

                $("#title").val("");

                $("#message").val("");

                $("#imageFile").val("");

                $("#previewImage").hide();

          

                loadPosts();
            },

            error: function (xhr) {

                console.log(xhr);

                alert(
                    xhr.responseText ||
                    "Failed to add post"
                );
            }
        });
    }

 

    function loadPosts() {

        let communityId =
            "@Context.Session.GetString("CommunityId")";

        $.get(

            `/api/Community/GetCommunityPosts/${communityId}`,

            function (res) {

                let html = "";


                if (res.data.length == 0) {

                    html = `
                        <tr>

                            <td colspan="6"
                                class="text-center text-muted">

                                No posts found

                            </td>

                        </tr>`;
                }

           

                res.data.forEach((p, index) => {

                    html += `

                        <tr>

                            <td>
                                ${index + 1}
                            </td>

                            <td>

                                ${p.imagePath
                            ?
                            `<img src="${p.imagePath}"
                                          style="
                                            width:90px;
                                            height:70px;
                                            object-fit:cover;
                                            border-radius:8px;">`
                            :
                            `<span class="text-muted">
                                        No Image
                                     </span>`
                        }

                            </td>

                            <td>

                                <strong>

                                    ${p.title}

                                </strong>

                            </td>

                            <td>

                                ${p.message}

                            </td>

                            <td>

                                ${p.createdDateString}

                            </td>

                            <td>

                                <button class="btn btn-danger btn-sm"
                                        onclick="deletePost(${p.postId})">

                                    <i class="fa-solid fa-trash"></i>

                                    Delete

                                </button>

                            </td>

                        </tr>`;
                });

                $("#postsContainer").html(html);
            });
    }


    function deletePost(postId) {

        if (!confirm(
            "Are you sure you want to delete this post?"
        )) {
            return;
        }

        $.ajax({

            url:
                `/api/Community/DeleteCommunityPost/${postId}`,

            type: "DELETE",

            success: function (res) {

                alert(
                    res.resultMessage ||
                    "Post deleted successfully"
                );

                loadPosts();
            },

            error: function () {

                alert("Failed to delete post");
            }
        });
    }

</script>