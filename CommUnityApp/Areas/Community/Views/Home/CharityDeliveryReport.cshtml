@{
    ViewData["Title"] = "Charity Delivery Report";
    Layout = "~/Areas/Community/Views/Shared/_CommunityLayout.cshtml";
}

<h3 class="mb-3">Delivery Report</h3>

<div class="card shadow-sm">
    <div class="card-body">

        <button class="btn btn-danger mb-3" onclick="printPDF()">Print PDF</button>

        <div id="printArea">
            <table class="table table-bordered table-striped" id="tblRequests">
                <thead class="table-dark">
                    <tr>
                        <th style="width:60px;">#</th>
                        <th>Item</th>
                        <th>Receiver Name</th>
                        <th>Mobile</th>
                        <th>Qty</th>
                        <th>Delivered Volunteer</th>
                        <th>Delivery Status</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="8" class="text-center">Loading...</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between mt-3">
            <div>
                <strong>Showing:</strong> <span id="pageInfo"></span>
            </div>
            <div>
                <button class="btn btn-sm btn-primary" onclick="prevPage()">Prev</button>
                <span id="currentPage" class="mx-2">1</span>
                <button class="btn btn-sm btn-primary" onclick="nextPage()">Next</button>
            </div>
        </div>

    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    var allData = [];
    var pageSize = 10;
    var currentPage = 1;

    $(document).ready(function () {
        loadRequests();
    });

    function loadRequests() {
        $.ajax({
            url: '/api/Community/GetCharityItemRequestsList',
            type: 'GET',
            success: function (res) {
                allData = res || [];
                currentPage = 1;
                renderTable();
            }
        });
    }

    function renderTable() {
        var html = "";

        var start = (currentPage - 1) * pageSize;
        var end = start + pageSize;
        var pageData = allData.slice(start, end);

        if (pageData.length === 0) {
            html += "<tr><td colspan='8' class='text-center'>No records found</td></tr>";
        }
        else {
            $.each(pageData, function (i, item) {

                var rowNumber = start + i + 1;

                html += "<tr>";
                html += "<td>" + rowNumber + "</td>";
                html += "<td>" + item.itemName + "</td>";
                html += "<td>" + item.requestedUserName + "</td>";
                html += "<td>" + (item.mobile || "-") + "</td>";
                html += "<td>" + item.requestedQuantity + "</td>";
                html += "<td>" + (item.volunteerName || "-") + "</td>";
                html += "<td>" + (item.deliveryStatus || "-") + "</td>";
                html += "<td>" + new Date(item.createdDate).toLocaleDateString() + "</td>";
                html += "</tr>";
            });
        }

        $("#tblRequests tbody").html(html);

        $("#currentPage").text(currentPage);
        $("#pageInfo").text((start + 1) + " - " + Math.min(end, allData.length) + " of " + allData.length);
    }

    function nextPage() {
        if ((currentPage * pageSize) < allData.length) {
            currentPage++;
            renderTable();
        }
    }

    function prevPage() {
        if (currentPage > 1) {
            currentPage--;
            renderTable();
        }
    }

    function printPDF() {
        var printContents = document.getElementById("printArea").innerHTML;
        var originalContents = document.body.innerHTML;

        document.body.innerHTML = printContents;
        window.print();
        document.body.innerHTML = originalContents;
        location.reload();
    }
</script>