@{
    ViewData["Title"] = "Event Ticket Bookings";
    Layout = "~/Areas/Community/Views/Shared/_CommunityLayout.cshtml";
}

<style>
    .summary-card {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 18px;
        border-radius: 12px;
        color: #fff;
        font-family: 'Segoe UI', sans-serif;
        box-shadow: 0 4px 12px rgba(0,0,0,.1);
        transition: .3s;
    }

        .summary-card:hover {
            transform: translateY(-4px);
        }

    .summary-icon {
        font-size: 26px;
        background: rgba(255,255,255,.2);
        padding: 10px;
        border-radius: 10px;
    }

    .summary-title {
        font-size: 14px;
        opacity: .9;
    }

    .summary-value {
        font-size: 22px;
        font-weight: bold;
    }

    .booking-card {
        background: linear-gradient(135deg,#667eea,#764ba2);
    }

    .amount-card {
        background: linear-gradient(135deg,#43e97b,#38f9d7);
    }

    .badge-success {
        background: #28a745;
        color: #fff;
        padding: 5px 10px;
        border-radius: 12px;
    }

    .badge-failed {
        background: #dc3545;
        color: #fff;
        padding: 5px 10px;
        border-radius: 12px;
    }

    .badge-pending {
        background: #ffc107;
        color: #000;
        padding: 5px 10px;
        border-radius: 12px;
    }

    table td {
        vertical-align: middle;
    }
</style>

<div class="card">
    <div class="card-body">

        <h4 class="mb-4">🎫 Event Ticket Bookings</h4>

        <div class="row mb-4">

            <div class="col-md-3">
                <div class="summary-card booking-card">
                    <div class="summary-icon">🎟️</div>
                    <div>
                        <div class="summary-title">Total Bookings</div>
                        <div class="summary-value" id="totalBookings">0</div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="summary-card amount-card">
                    <div class="summary-icon">💰</div>
                    <div>
                        <div class="summary-title">Total Revenue</div>
                        <div class="summary-value" id="totalRevenue">₹ 0</div>
                    </div>
                </div>
            </div>

        </div>

        <div class="table-responsive">

            <table class="table table-bordered table-striped table-hover">

                <thead class="table-dark">

                    <tr>
                        <th>#</th>
                        <th>Booking Id</th>
                        <th>Member</th>
                        <th>Email</th>
                        <th>Mobile</th>
                        <th>No. Tickets</th>
                        <th>Total Amount</th>
                        <th>Wallet Used</th>
                        <th>Paid Amount</th>
                        <th>Payment Method</th>
                        <th>Payment Status</th>
                        <th>Booking Date</th>
                        <th>Transaction Id</th>
                    </tr>

                </thead>

                <tbody id="bookingTable"></tbody>

            </table>

        </div>

    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>

    $(function () {

        const urlParams = new URLSearchParams(window.location.search);
        const eventId = urlParams.get("eventId");

        if (!eventId) {

            $("#bookingTable").html(
                "<tr><td colspan='13' class='text-center text-danger'>Invalid Event</td></tr>");

            return;
        }

        $.get("/api/Event/GetEventTicketBookings?eventId=" + eventId,

            function (res) {

                let html = "";
                let totalRevenue = 0;
                let totalBookings = 0;

                if (!res.status || !res.data || res.data.length == 0) {

                    $("#bookingTable").html(
                        "<tr><td colspan='13' class='text-center'>No bookings found.</td></tr>");

                    return;
                }

                $.each(res.data, function (i, item) {

                    totalBookings++;
                    totalRevenue += parseFloat(item.totalAmount || 0);

                    let paymentBadge = "";

                    if ((item.paymentStatus || "").toLowerCase() == "success")
                        paymentBadge = "<span class='badge-success'>Success</span>";
                    else if ((item.paymentStatus || "").toLowerCase() == "failed")
                        paymentBadge = "<span class='badge-failed'>Failed</span>";
                    else
                        paymentBadge = "<span class='badge-pending'>Pending</span>";

                    html += `
                        <tr>

                            <td>${i + 1}</td>

                            <td>${item.bookingId}</td>

                            <td>${item.memberName}</td>

                            <td>${item.email}</td>

                            <td>${item.mobile}</td>

                            <td class="text-center">${item.noOfTickets}</td>

                            <td>₹ ${parseFloat(item.totalAmount).toFixed(2)}</td>

                            <td>₹ ${parseFloat(item.walletUsed).toFixed(2)}</td>

                            <td>₹ ${parseFloat(item.payableAmount).toFixed(2)}</td>

                            <td>${item.paymentMethod}</td>

                            <td>${paymentBadge}</td>

    <td>
        ${new Date(item.bookingDate).toLocaleString('en-IN', {
                        day: '2-digit',
                        month: '2-digit',
                        year: 'numeric',
                        hour: '2-digit',
                        minute: '2-digit',
                        hour12: true
                    })}
    </td>
                            <td style="font-size:12px;">${item.transactionId ?? "-"}</td>

                        </tr>`;
                });

                $("#bookingTable").html(html);

                $("#totalBookings").text(totalBookings);

                $("#totalRevenue").text("₹ " + totalRevenue.toFixed(2));

            });

    });

</script>