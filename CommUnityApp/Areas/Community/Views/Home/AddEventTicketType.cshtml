@{
    ViewData["Title"] = "Add / Update Event Ticket Type";
    Layout = "~/Areas/Community/Views/Shared/_CommunityLayout.cshtml";
}

<div class="container-fluid mt-4">

    <div class="card shadow">
        <div class="card-header text-white" style="background-color:black;">
            <h4 class="mb-3">Add Event Ticket Type</h4>
        </div>

        <div class="card-body">

            <div class="row">

                <div class="col-md-6 mb-3">
                    <label class="form-label">Event</label>
                    <select id="EventId" class="form-control">
                        <option value="">Select Event</option>
                    </select>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Ticket Type Name</label>
                    <input type="text"
                           id="TicketTypeName"
                           class="form-control"
                           placeholder="Enter Ticket Type Name" />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Price</label>
                    <input type="number"
                           id="Price"
                           class="form-control"
                           placeholder="Enter Price" />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Total Tickets</label>
                    <input type="number"
                           id="TotalTickets"
                           class="form-control"
                           placeholder="Enter Total Tickets" />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Max Per User</label>
                    <input type="number"
                           id="MaxPerUser"
                           class="form-control"
                           placeholder="Enter Max Tickets Per User" />
                </div>

                <div class="col-md-12 mb-3">
                    <label class="form-label">Conditions Apply</label>
                    <textarea id="ConditionsApply"
                              rows="4"
                              class="form-control"
                              placeholder="Enter Ticket Conditions"></textarea>
                </div>

                <div class="col-md-12 mb-3">
                    <label class="form-label">Refund Policy</label>
                    <textarea id="RefundPolicy"
                              rows="4"
                              class="form-control"
                              placeholder="Enter Refund Policy"></textarea>
                </div>

                <div class="col-md-12 mb-3">
                    <div class="form-check">
                        <input class="form-check-input"
                               type="checkbox"
                               id="IsTransferable">

                        <label class="form-check-label"
                               for="IsTransferable">
                            Is Transferable
                        </label>
                    </div>
                </div>

            </div>

            <div class="text-end">

                <button type="button"
                        class="btn btn-success"
                        onclick="AddEventTicketType();">
                    Save Ticket Type
                </button>

            </div>

        </div>
    </div>

</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>

    $(document).ready(function () {

        LoadEvents();

    });

    function LoadEvents() {

        $.ajax({
            url: '/api/Event/GetEventsDropdown',
            type: 'GET',
            success: function (response) {

                $("#EventId").empty();

                $("#EventId").append(
                    '<option value="">Select Event</option>');

                $.each(response, function (i, item) {

                    $("#EventId").append(
                        '<option value="' + item.eventId + '">' +
                        item.eventName +
                        '</option>');
                });

            },
            error: function () {

                alert("Failed to load events.");

            }
        });
    }

    function AddEventTicketType() {

        if ($("#EventId").val() == "") {
            alert("Please select Event");
            return;
        }

        var model = {
            EventId: parseInt($("#EventId").val()) || 0,
            TicketTypeName: $("#TicketTypeName").val(),
            Price: parseFloat($("#Price").val()) || 0,
            TotalTickets: parseInt($("#TotalTickets").val()) || 0,
            MaxPerUser: parseInt($("#MaxPerUser").val()) || 0,
            ConditionsApply: $("#ConditionsApply").val(),
            RefundPolicy: $("#RefundPolicy").val(),
            IsTransferable: $("#IsTransferable").is(":checked")
        };

        $.ajax({
            url: '/api/Event/AddEventTicketType',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(model),

            success: function (response) {

                alert("Ticket Type Added Successfully");

                $("#EventId").val("");
                $("#TicketTypeName").val("");
                $("#Price").val("");
                $("#TotalTickets").val("");
                $("#MaxPerUser").val("");
                $("#ConditionsApply").val("");
                $("#RefundPolicy").val("");
                $("#IsTransferable").prop("checked", false);
                 
                window.location.href = "/Community/Home/ViewEventTicketType";
            },

            error: function (xhr) {

                console.log(xhr.responseText);
                alert("Failed to add ticket type");
            }
        });
    }

</script>